@{
    ViewBag.Title = "Home";
     Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* ================== ROOT ================== */
    :root {
        --bg: #f4f6fb;
        --surface: #ffffff;
        --border: #e8ecf4;
        --text: #1a1f36;
        --muted: #8892a4;
        /* status */
        --todo: #64748b;
        --inprogress: #4f6ef7;
        --done: #22c55e;
        --overdue: #ef4444;
        --accent: #4f6ef7;
    }

    /* ================== RESET ================== */
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
    }

    /* ================== LAYOUT ================== */
    .page-content {
        padding: 28px;
    }

    /* ================= Sidebar ================= */
    .sidebar {
        width: 240px;
        background: var(--surface);
        border-right: 1px solid var(--border);
        height: 100vh;
        position: fixed;
        top: 0;
        left: 0;
        display: flex;
        flex-direction: column;
        padding: 28px 20px;
    }

    .logo {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--accent);
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 36px;
    }

    .logo-icon {
        width: 36px;
        height: 36px;
        background: var(--accent);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 14px;
        border-radius: 10px;
        color: var(--muted);
        font-size: 0.9rem;
        cursor: pointer;
        text-decoration: none;
    }

        .nav-item:hover {
            background: #f0f3ff;
            color: var(--accent);
        }

        .nav-item.active {
            background: #eef1ff;
            color: var(--accent);
            font-weight: 600;
        }

    .nav-section {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 20px 0 8px 14px;
    }

    /* ================= Header ================= */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
    }

    .page-sub {
        color: var(--muted);
        font-size: 0.9rem;
    }

    .btn-new {
        background: var(--accent);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-weight: 600;
        cursor: pointer;
    }

        .btn-new:hover {
            opacity: 0.85;
        }

    /* ================= Stat ================= */
    .stat-grid-task {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 20px;
        margin-bottom: 28px;
    }

    .stat-card {
        cursor: pointer;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 22px 24px;
        position: relative;
        transition: 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(79,110,247,0.1);
        }

    .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 14px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        font-family: 'DM Mono', monospace;
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--muted);
    }

    .stat-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 0.72rem;
        padding: 3px 8px;
        border-radius: 20px;
    }

    /* ================= Filter ================= */
    .filter-bar {
        display: flex;
        gap: 10px;
        margin-bottom: 24px;
        flex-wrap: wrap;
    }

    .search-wrap {
        position: relative;
        flex: 1;
        min-width: 200px;
    }

        .search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
        }

    .filter-input {
        width: 100%;
        padding: 10px 14px 10px 36px;
        border: 1px solid var(--border);
        border-radius: 10px;
    }

    .filter-select {
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: 10px;
    }

    /* ================= Kanban ================= */
    .bottom-grid-kanban {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 20px;
    }

    .card-box {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 16px;
    }

    .card-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 14px;
    }

    /* Header */
    .kanban-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 14px;
    }

    .kanban-title {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--muted);
    }

    .kanban-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    .kanban-count {
        font-size: 0.75rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 1px 8px;
    }

    /* ================= Task ================= */
    .task-item {
        display: flex;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

    .task-check {
        width: 18px;
        height: 18px;
        border-radius: 5px;
        border: 2px solid var(--border);
    }

        .task-check.done {
            background: var(--done);
            border-color: var(--done);
        }

    .task-name {
        flex: 1;
        font-weight: 500;
    }

        .task-name.done-text {
            text-decoration: line-through;
            color: var(--muted);
        }

    .task-tag {
        font-size: 0.72rem;
        padding: 3px 9px;
        border-radius: 20px;
    }

    .tag-todo {
        background: #f1f5f9;
        color: var(--todo);
    }

    .tag-inprogress {
        background: #eef1ff;
        color: var(--inprogress);
    }

    .tag-done {
        background: #f0fdf4;
        color: var(--done);
    }

    .tag-overdue {
        background: #fef2f2;
        color: var(--overdue);
    }

    .task-date {
        font-size: 0.78rem;
        color: var(--muted);
    }

    /* Priority */
    .task-priority {
        font-size: 0.72rem;
        margin-bottom: 4px;
    }

    .priority-high {
        color: var(--overdue);
    }

    .priority-medium {
        color: #f59e0b;
    }

    .priority-low {
        color: var(--done);
    }

    /* Progress */
    .progress-wrap {
        flex: 1;
        height: 4px;
        background: var(--border);
        border-radius: 4px;
    }

    .progress-bar-fill {
        height: 100%;
        background: var(--accent);
    }

    .progress-pct {
        font-size: 0.68rem;
        color: var(--muted);
    }

    /* Avatar */
    .task-avatar {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: var(--accent);
        color: white;
        font-size: 0.6rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    /* Empty */
    .kanban-empty {
        text-align: center;
        color: var(--muted);
        font-size: 0.8rem;
        padding: 24px 0;
    }
</style>
<div class="page-content">

    <!-- Header -->
    <div class="page-header">
        <div>
            <div class="page-title">My Tasks</div>
            <div class="page-sub">Your assigned tasks — @DateTime.Now.ToString("dddd, MMMM d yyyy")</div>
        </div>
        <div style="display:flex; gap:8px">
            <button class="btn-new" data-bs-toggle="modal" data-bs-target="#insertModal">
                <i class="bi bi-plus me-1"></i> New Task
            </button>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="stat-grid-task">
        <div class="stat-card">
            <div class="stat-icon" style="background:#3B82F61A"><i class="bi bi-person-check" style="color:#3B82F6"></i></div>
            <div class="stat-value" id="cntTodo" style="color:#3B82F6">7</div>
            <div class="stat-label">Assigned</div>
            <span class="stat-badge" style="background:#3B82F61A;color:#3B82F6">Assigned</span>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background:#4F6EF71A"><i class="bi bi-tools" style="color:#4F6EF7"></i></div>
            <div class="stat-value" id="cntInprogress" style="color:#4F6EF7">14</div>
            <div class="stat-label">In Progress</div>
            <span class="stat-badge" style="background:#4F6EF71A;color:#4F6EF7">In Progress</span>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background:#F59E0B1A"><i class="bi bi-pause-circle" style="color:#F59E0B"></i></div>
            <div class="stat-value" id="cntDone" style="color:#F59E0B">27</div>
            <div class="stat-label">On Hold</div>
            <span class="stat-badge" style="background:#F59E0B1A;color:#F59E0B">On Hold</span>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background:#22C55E1A"><i class="bi bi-check-circle" style="color:#22C55E"></i></div>
            <div class="stat-value" id="cntOverdue" style="color:#22C55E">7</div>
            <div class="stat-label">Completed</div>
            <span class="stat-badge" style="background:#22C55E1A;color:#22C55E">Completed</span>
        </div>

        <div class="stat-card">
            <div class="stat-icon" style="background:#F973161A"><i class="bi bi-exclamation-triangle" style="color:#F97316"></i></div>
            <div class="stat-value" id="cntOverdue" style="color:#F97316">7</div>
            <div class="stat-label">Overdue</div>
            <span class="stat-badge" style="background:#F973161A;color:#F97316">Overdue</span>
        </div>
    </div>
    <!-- Filter Bar -->
    <div class="filter-bar">
        <div class="search-wrap">
            <i class="bi bi-search"></i>
            <input type="text" class="filter-input" id="searchInput" placeholder="Search tasks...">
        </div>
        <select class="filter-select" id="filterPriority">
            <option value="">All Priority</option>
            <option value="High">High</option>
            <option value="Medium">Medium</option>
            <option value="Low">Low</option>
        </select>
        <select class="filter-select" id="filterAssign">
            <option value="">All Assigned</option>
            <option value="SK">Somchai K.</option>
            <option value="NS">Nattapol S.</option>
            <option value="KW">Krit W.</option>
        </select>
        <button class="btn-new" onclick="resetFilter()" style="background:var(--muted); padding:10px 16px">
            <i class="bi bi-x-lg me-1"></i> Reset
        </button>
    </div>

    <!-- Kanban Board — ใช้ .bottom-grid + .card-box -->
    <div class="bottom-grid-kanban">

        <!-- To Do -->
        <div class="card-box">
            <div class="kanban-header">
                <div class="kanban-title">
                    <div class="kanban-dot" style="background:var(--todo)"></div>
                    To Do
                </div>
                <span class="kanban-count" id="badge-todo">0</span>
            </div>
            <div id="col-todo"></div>
        </div>

        <!-- In Progress -->
        <div class="card-box">
            <div class="kanban-header">
                <div class="kanban-title">
                    <div class="kanban-dot" style="background:var(--inprogress)"></div>
                    In Progress
                </div>
                <span class="kanban-count" id="badge-inprogress">0</span>
            </div>
            <div id="col-inprogress"></div>
        </div>

        <!-- Done -->
        <div class="card-box">
            <div class="kanban-header">
                <div class="kanban-title">
                    <div class="kanban-dot" style="background:var(--done)"></div>
                    Completed
                </div>
                <span class="kanban-count" id="badge-done">0</span>
            </div>
            <div id="col-done"></div>
        </div>

        <!-- Overdue -->
        <div class="card-box">
            <div class="kanban-header">
                <div class="kanban-title">
                    <div class="kanban-dot" style="background:var(--overdue)"></div>
                    Overdue
                </div>
                <span class="kanban-count" id="badge-overdue">0</span>
            </div>
            <div id="col-overdue"></div>
        </div>

    </div>

</div>

<script>
    const tasks = [
        { title: 'Design new landing page mockup',  status: 'inprogress', priority: 'High',   date: 'Mar 14', assign: 'SK', progress: 60 },
        { title: 'Setup CI/CD pipeline',            status: 'done',       priority: 'Medium', date: 'Mar 12', assign: 'NS', progress: 100 },
        { title: 'Write API documentation',         status: 'overdue',    priority: 'High',   date: 'Mar 10', assign: 'SK', progress: 30 },
        { title: 'User authentication module',      status: 'inprogress', priority: 'High',   date: 'Mar 15', assign: 'KW', progress: 75 },
        { title: 'Database schema review',          status: 'todo',       priority: 'Low',    date: 'Mar 18', assign: 'NS', progress: 0 },
        { title: 'Fix login bug on mobile',         status: 'done',       priority: 'High',   date: 'Mar 11', assign: 'SK', progress: 100 },
        { title: 'Performance testing report',      status: 'overdue',    priority: 'Medium', date: 'Mar 9',  assign: 'KW', progress: 20 },
        { title: 'Update dependencies to latest',   status: 'todo',       priority: 'Low',    date: 'Mar 20', assign: 'NS', progress: 0 },
        { title: 'Code review for PR #42',          status: 'inprogress', priority: 'Medium', date: 'Mar 16', assign: 'SK', progress: 50 },
        { title: 'Deploy to staging server',        status: 'todo',       priority: 'High',   date: 'Mar 19', assign: 'KW', progress: 0 },
        { title: 'Fix chart rendering bug',         status: 'done',       priority: 'Low',    date: 'Mar 13', assign: 'NS', progress: 100 },
        { title: 'Prepare release notes v2.0',      status: 'overdue',    priority: 'Medium', date: 'Mar 8',  assign: 'SK', progress: 10 },
    ];

    const tagMap = {
        todo:       { label: 'To Do',      cls: 'tag-todo',       bg: '#f1f5f9', color: 'var(--todo)' },
        inprogress: { label: 'In Progress', cls: 'tag-inprogress', bg: '#eef1ff', color: 'var(--inprogress)' },
        done:       { label: 'Done',        cls: 'tag-done',       bg: '#f0fdf4', color: 'var(--done)' },
        overdue:    { label: 'Overdue',     cls: 'tag-overdue',    bg: '#fef2f2', color: 'var(--overdue)' },
    };

    function buildCard(t) {
        const priClass = t.priority === 'High' ? 'priority-high' : t.priority === 'Medium' ? 'priority-medium' : 'priority-low';
        const priIcon  = t.priority === 'High' ? 'bi-arrow-up-circle-fill' : t.priority === 'Medium' ? 'bi-dash-circle-fill' : 'bi-arrow-down-circle-fill';
        const doneText = t.status === 'done' ? 'done-text' : '';
        const checkCls = t.status === 'done' ? 'done' : t.status === 'inprogress' ? 'inprogress' : '';
        const checkIcon = t.status === 'done' ? '✓' : '';
        return `
            <div class="task-item"
                 data-title="${t.title.toLowerCase()}"
                 data-priority="${t.priority}"
                 data-assign="${t.assign}">
                <div class="task-check ${checkCls}">${checkIcon}</div>
                <div class="task-name ${doneText}" style="flex:1">
                    <div class="task-priority ${priClass}">
                        <i class="bi ${priIcon}"></i> ${t.priority}
                    </div>
                    ${t.title}
                </div>
                <span class="task-tag tag-${t.status}">${t.status === 'inprogress' ? 'In Progress' : t.status.charAt(0).toUpperCase() + t.status.slice(1)}</span>
                <div class="task-date">${t.date}</div>
            </div>
            <div style="padding: 6px 0 10px; display:flex; align-items:center; gap:6px; border-bottom:1px solid var(--border)">
                <div class="task-avatar">${t.assign}</div>
                <div class="progress-wrap">
                    <div class="progress-bar-fill" style="width:${t.progress}%"></div>
                </div>
                <div class="progress-pct">${t.progress}%</div>
            </div>`;
    }

    function renderBoard(data) {
        const cols = { todo: '', inprogress: '', done: '', overdue: '' };
        const cnt  = { todo: 0, inprogress: 0, done: 0, overdue: 0 };

        data.forEach(t => {
            if (cols[t.status] !== undefined) {
                cols[t.status] += buildCard(t);
                cnt[t.status]++;
            }
        });

        Object.keys(cols).forEach(k => {
            document.getElementById('col-' + k).innerHTML =
                cols[k] || `<div class="kanban-empty"><i class="bi bi-inbox"></i>No tasks</div>`;
            document.getElementById('badge-' + k).textContent = cnt[k];
        });
    }

    function applyFilter() {
        const search   = document.getElementById('searchInput').value.toLowerCase();
        const priority = document.getElementById('filterPriority').value;
        const assign   = document.getElementById('filterAssign').value;

        const filtered = tasks.filter(t => {
            const matchSearch   = !search   || t.title.toLowerCase().includes(search);
            const matchPriority = !priority || t.priority === priority;
            const matchAssign   = !assign   || t.assign === assign;
            return matchSearch && matchPriority && matchAssign;
        });

        renderBoard(filtered);
    }

    function resetFilter() {
        document.getElementById('searchInput').value       = '';
        document.getElementById('filterPriority').value   = '';
        document.getElementById('filterAssign').value     = '';
        renderBoard(tasks);
    }

    document.getElementById('searchInput').addEventListener('input', applyFilter);
    document.getElementById('filterPriority').addEventListener('change', applyFilter);
    document.getElementById('filterAssign').addEventListener('change', applyFilter);

    renderBoard(tasks);
</script>

