  <style>
        :root {
            --bg: #f4f6fb;
            --surface: #ffffff;
            --border: #e8ecf4;
            --text: #1a1f36;
            --muted: #8892a4;
        --accent: #003A8F;
            --todo: #94a3b8;
            --inprogress: #4f6ef7;
            --done: #22c55e;
            --overdue: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 240px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 28px 20px;
        }

        .logo {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 36px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--accent);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 10px;
            color: var(--muted);
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            margin-bottom: 4px;
        }

            .nav-item:hover {
                background: #f0f3ff;
                color: var(--accent);
            }

            .nav-item.active {
                background: #eef1ff;
                color: var(--accent);
                font-weight: 600;
            }

        .nav-section {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 20px 0 8px 14px;
        }

        
        

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .page-title {
            font-size: 1.6rem;
            font-weight: 700;
        }

        .page-sub {
            color: var(--muted);
            font-size: 0.9rem;
            margin-top: 4px;
        }

        .btn-new {
            background: var(--accent);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: opacity 0.2s;
        }

            .btn-new:hover {
                opacity: 0.85;
            }

        /* Stat Cards */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 22px 24px;
            position: relative !important;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            animation: fadeUp 0.5s ease both;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(79,110,247,0.1);
            }

            .stat-card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .stat-card:nth-child(2) {
                animation-delay: 0.1s;
            }

            .stat-card:nth-child(3) {
                animation-delay: 0.15s;
            }

            .stat-card:nth-child(4) {
                animation-delay: 0.2s;
            }

        .stat-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-bottom: 14px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            font-family: 'DM Mono', monospace;
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-label {
            font-size: 0.85rem;
            color: var(--muted);
            font-weight: 500;
        }

        .stat-badge {
            position: absolute !important;
            top: 20px;
            right: 20px;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 20px;
        }

        /* Bottom Grid */
        .bottom-grid {
            display: grid;
            grid-template-columns: 1fr 1.6fr;
            gap: 20px;
        }

        .card-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            animation: fadeUp 0.5s ease both;
            animation-delay: 0.3s;
        }

        .card-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .card-title span {
                color: var(--muted);
                font-size: 0.8rem;
                font-weight: 500;
            }

        /* Donut */
        .donut-wrap {
            position: relative;
            width: 200px;
            margin: 0 auto 24px;
        }

        .donut-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .donut-total {
            font-size: 1.8rem;
            font-weight: 700;
            font-family: 'DM Mono', monospace;
        }

        .donut-sub {
            font-size: 0.75rem;
            color: var(--muted);
        }

        .legend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
        }

            .legend-item:last-child {
                border-bottom: none;
            }

        .legend-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .legend-left {
            display: flex;
            align-items: center;
        }

        .legend-count {
            font-weight: 600;
            font-family: 'DM Mono', monospace;
        }

        /* Task List */
        .task-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.88rem;
            transition: background 0.15s;
        }

            .task-item:last-child {
                border-bottom: none;
            }

        .task-check {
            width: 18px;
            height: 18px;
            border-radius: 5px;
            border: 2px solid var(--border);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
        }

            .task-check.done {
                background: var(--done);
                border-color: var(--done);
                color: white;
            }

            .task-check.inprogress {
                border-color: var(--inprogress);
            }

        .task-name {
            flex: 1;
            font-weight: 500;
        }

            .task-name.done-text {
                text-decoration: line-through;
                color: var(--muted);
            }

        .task-tag {
            font-size: 0.72rem;
            font-weight: 600;
            padding: 3px 9px;
            border-radius: 20px;
        }

        .tag-todo {
            background: #f1f5f9;
            color: var(--todo);
        }

        .tag-inprogress {
            background: #eef1ff;
            color: var(--inprogress);
        }

        .tag-done {
            background: #f0fdf4;
            color: var(--done);
        }

        .tag-overdue {
            background: #fef2f2;
            color: var(--overdue);
        }

        .task-date {
            color: var(--muted);
            font-size: 0.78rem;
            font-family: 'DM Mono', monospace;
        }

      
        }
    </style>

    <!-- Main -->
    <div class="page-content">
        <div class="page-header">
            <div>
                <div class="page-title">Task Dashboard XXXXX BBBB</div>
                <div class="page-sub">Overview of all tasks — @DateTime.Now.ToString("dddd, MMMM d yyyy")</div>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="stat-grid">
            <div class="stat-card">
                <div class="stat-icon" style="background:#f0f3ff">📋</div>
                <div class="stat-value" style="color:var(--text)">48</div>
                <div class="stat-label">Total Tasks</div>
                <span class="stat-badge" style="background:#f0f3ff;color:var(--accent)">All</span>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#eef1ff">⚡</div>
                <div class="stat-value" style="color:var(--inprogress)">14</div>
                <div class="stat-label">In Progress</div>
                <span class="stat-badge" style="background:#eef1ff;color:var(--inprogress)">Active</span>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#f0fdf4">✅</div>
                <div class="stat-value" style="color:var(--done)">27</div>
                <div class="stat-label">Completed</div>
                <span class="stat-badge" style="background:#f0fdf4;color:var(--done)">56%</span>
            </div>
            <div class="stat-card">
                <div class="stat-icon" style="background:#fef2f2">🔥</div>
                <div class="stat-value" style="color:var(--overdue)">7</div>
                <div class="stat-label">Overdue</div>
                <span class="stat-badge" style="background:#fef2f2;color:var(--overdue)">Urgent</span>
            </div>
        </div>

        <!-- Bottom -->
        <div class="bottom-grid">

            <!-- Donut Chart -->
            <div class="card-box">
                <div class="card-title">Task Overview <span>All Projects</span></div>
                <div class="donut-wrap">
                    <canvas id="donutChart" width="200" height="200"></canvas>
                    <div class="donut-center">
                        <div class="donut-total">48</div>
                        <div class="donut-sub">Total</div>
                    </div>
                </div>
                <div>
                    <div class="legend-item">
                        <div class="legend-left">
                            <div class="legend-dot" style="background:#94a3b8"></div>
                            To Do
                        </div>
                        <span class="legend-count">7</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-left">
                            <div class="legend-dot" style="background:#4f6ef7"></div>
                            In Progress
                        </div>
                        <span class="legend-count">14</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-left">
                            <div class="legend-dot" style="background:#22c55e"></div>
                            Completed
                        </div>
                        <span class="legend-count">27</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-left">
                            <div class="legend-dot" style="background:#ef4444"></div>
                            Overdue
                        </div>
                        <span class="legend-count">7</span>
                    </div>
                    <div class="legend-item" style="border-bottom:none">
                        <div class="legend-left">
                            <div class="legend-dot" style="background:#a855f7"></div>
                            On Hold
                        </div>
                        <span class="legend-count">3</span>
                    </div>
                </div>
            </div>

            <!-- Task List -->
            <div class="card-box" style="animation-delay:0.35s">
                <div class="card-title">Recent Tasks <span>View all →</span></div>

                <div class="task-item">
                    <div class="task-check inprogress"></div>
                    <div class="task-name">Design new landing page mockup</div>
                    <span class="task-tag tag-inprogress">In Progress</span>
                    <div class="task-date">Mar 14</div>
                </div>
                <div class="task-item">
                    <div class="task-check done">✓</div>
                    <div class="task-name done-text">Setup CI/CD pipeline</div>
                    <span class="task-tag tag-done">Done</span>
                    <div class="task-date">Mar 12</div>
                </div>
                <div class="task-item">
                    <div class="task-check"></div>
                    <div class="task-name">Write API documentation</div>
                    <span class="task-tag tag-overdue">Overdue</span>
                    <div class="task-date">Mar 10</div>
                </div>
                <div class="task-item">
                    <div class="task-check inprogress"></div>
                    <div class="task-name">User authentication module</div>
                    <span class="task-tag tag-inprogress">In Progress</span>
                    <div class="task-date">Mar 15</div>
                </div>
                <div class="task-item">
                    <div class="task-check"></div>
                    <div class="task-name">Database schema review</div>
                    <span class="task-tag tag-todo">To Do</span>
                    <div class="task-date">Mar 18</div>
                </div>
                <div class="task-item">
                    <div class="task-check done">✓</div>
                    <div class="task-name done-text">Fix login bug on mobile</div>
                    <span class="task-tag tag-done">Done</span>
                    <div class="task-date">Mar 11</div>
                </div>
                <div class="task-item">
                    <div class="task-check"></div>
                    <div class="task-name">Performance testing report</div>
                    <span class="task-tag tag-overdue">Overdue</span>
                    <div class="task-date">Mar 9</div>
                </div>
                <div class="task-item">
                    <div class="task-check"></div>
                    <div class="task-name">Update dependencies to latest</div>
                    <span class="task-tag tag-todo">To Do</span>
                    <div class="task-date">Mar 20</div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        new Chart(document.getElementById('donutChart'), {
            type: 'doughnut',
            data: {
                labels: ['To Do', 'In Progress', 'Completed', 'Overdue', 'On Hold'],
                datasets: [{
                    data: [7, 14, 27, 7, 3],
                    backgroundColor: ['#94a3b8', '#4f6ef7', '#22c55e', '#ef4444', '#a855f7'],
                    borderWidth: 0,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: false,
                cutout: '72%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: ctx => ` ${ctx.label}: ${ctx.parsed} tasks`
                        }
                    }
                }
            }
        });
    </script>


