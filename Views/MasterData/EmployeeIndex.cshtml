@{
    ViewBag.Title = "MasterData";
    Layout = "~/Views/Shared/_MasterDataLayout.cshtml";
}

<style>
    :root {
        --bg: #f4f6fb;
        --surface: #ffffff;
        --border: #e8ecf4;
        --text: #1a1f36;
        --muted: #8892a4;
        --accent: #4f6ef7;
        --todo: #94a3b8;
        --inprogress: #4f6ef7;
        --done: #22c55e;
        --overdue: #ef4444;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        font-family: 'DM Sans', sans-serif;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
    }

    .page-content {
        padding: 28px;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 32px;
    }

    .page-title {
        font-size: 1.6rem;
        font-weight: 700;
    }

    .page-sub {
        color: var(--muted);
        font-size: 0.9rem;
        margin-top: 4px;
    }

    .btn-new {
        background: var(--accent);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity 0.2s;
        display: flex;
        align-items: center;
        gap: 6px;
    }

        .btn-new:hover {
            opacity: 0.85;
        }

    /* ── Stat Cards ── */
    .stat-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(0, 1fr));
        gap: 20px;
        margin-bottom: 28px;
    }

    .stat-card {
        cursor: pointer;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 22px 24px;
        position: relative;
        overflow: hidden;
        transition: transform 0.2s, box-shadow 0.2s;
        animation: fadeUp 0.5s ease both;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(79,110,247,0.1);
        }

        .stat-card:nth-child(1) {
            animation-delay: 0.05s;
        }

        .stat-card:nth-child(2) {
            animation-delay: 0.10s;
        }

        .stat-card:nth-child(3) {
            animation-delay: 0.15s;
        }

        .stat-card:nth-child(4) {
            animation-delay: 0.20s;
        }

        .stat-card * {
            pointer-events: none;
        }

    .stat-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        margin-bottom: 14px;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 700;
        font-family: 'DM Mono', monospace;
        line-height: 1;
        margin-bottom: 6px;
    }

    .stat-label {
        font-size: 0.85rem;
        color: var(--muted);
        font-weight: 500;
    }

    .stat-badge {
        position: absolute;
        top: 20px;
        right: 20px;
        font-size: 0.72rem;
        font-weight: 600;
        padding: 3px 8px;
        border-radius: 20px;
    }

    /* ── WC Grid ── */
    .wc-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 16px;
    }

    /* ── Card Box ── */
    .card-box {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        animation: fadeUp 0.5s ease both;
        animation-delay: 0.3s;
    }

    .card-title {
        font-size: 1rem;
        font-weight: 700;
        margin-bottom: 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

        .card-title span {
            color: var(--muted);
            font-size: 0.8rem;
            font-weight: 500;
        }

    /* ── Task Items ── */
    .task-item {
        display: flex;
        align-items: center;
        gap: 14px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
        font-size: 0.88rem;
    }

        .task-item:last-child {
            border-bottom: none;
        }

    .task-check {
        width: 18px;
        height: 18px;
        border-radius: 50%;
        background: #eef1ff;
        color: var(--accent);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.6rem;
        font-weight: 700;
        flex-shrink: 0;
    }

    .task-name {
        flex: 1;
        font-weight: 500;
    }

    .task-date {
        color: var(--muted);
        font-size: 0.78rem;
        font-family: 'DM Mono', monospace;
    }

    /* ── Breadcrumb ── */
    .bc {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 0.78rem;
        color: var(--muted);
        margin-bottom: 20px;
    }

    .bc-item {
        cursor: pointer;
        padding: 3px 8px;
        border-radius: 20px;
        transition: all .15s;
    }

        .bc-item:hover {
            background: var(--surface);
            color: var(--text);
        }

        .bc-item.active {
            color: var(--accent);
            font-weight: 600;
        }

    .bc-sep {
        color: var(--border);
    }

    /* ── Kanban Count ── */
    .kanban-count {
        font-size: 0.75rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-radius: 20px;
        padding: 1px 8px;
        color: var(--muted);
        font-family: 'DM Mono', monospace;
    }

    /* ── Buttons ── */
    .btn-add-inline {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        width: 100%;
        padding: 9px;
        border: 1px dashed var(--border);
        border-radius: 10px;
        background: none;
        color: var(--muted);
        font-family: 'DM Sans', sans-serif;
        font-size: 0.78rem;
        cursor: pointer;
        margin-top: 8px;
        transition: all .15s;
    }

        .btn-add-inline:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: #eef1ff;
        }

    .del-btn {
        width: 26px;
        height: 26px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: none;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all .15s;
        flex-shrink: 0;
    }

        .del-btn:hover {
            background: #fef2f2;
            border-color: #fecaca;
            color: var(--overdue);
        }

    /* ── Nav Section ── */
    .nav-section {
        font-size: 0.7rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--muted);
        margin: 0 0 12px 0;
    }

    /* ── Empty / Loading ── */
    .kanban-empty {
        text-align: center;
        color: var(--muted);
        font-size: 0.8rem;
        padding: 20px 0;
    }

        .kanban-empty i {
            font-size: 1.5rem;
            display: block;
            margin-bottom: 6px;
            opacity: .4;
        }

    .loading {
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        color: var(--muted);
        font-size: 0.82rem;
        gap: 8px;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(8px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .fade-in {
        animation: fadeUp .2s ease both;
    }
</style>

<div class="page-content" id="orgPageContent">

    <!-- Header -->
    <div class="page-header">
        <div>
            <div class="page-title">Organization Management</div>
            <div class="page-sub" id="orgDateSub">Factory workforce structure — @DateTime.Now.ToString("dddd, MMMM d yyyy")</div>
        </div>
    </div>

    <!-- Breadcrumb -->
    <div class="bc" id="bc">
        <span class="bc-item active">All Groups</span>
    </div>

    <!-- Level 1: Planner Groups -->
    <div id="lvl1">
        <div class="nav-section">Planner Group</div>
        <div class="stat-grid" id="pgCards">
            <div class="loading">
                <div class="spinner-border spinner-border-sm"></div> Loading...
            </div>
        </div>
    </div>

    <!-- Level 2: Planners -->
    <div id="lvl2" style="display:none">
        <div class="nav-section">Planner</div>
        <div class="stat-grid" id="planCards"></div>
    </div>

    <!-- Level 3: Work Centers + Workers -->
    <div id="lvl3" style="display:none">
        <div class="nav-section">Work Center &amp; Workers</div>
        <div class="wc-grid" id="wcGrid"></div>
    </div>

</div>

<!-- ── Modal Add Worker ── -->

<script>
    (function () {
        // ── Namespace ด้วย IIFE เพื่อกัน conflict ตอนโหลดซ้ำ ──

        // ── State ──
        let selPg = null, selPlan = null, selWc = null;
        let mSel = [], allAvail = [];

        // ── Expose functions ที่ใช้ใน inline onclick ──
        window.orgFilterWorkers = filterWorkers;
        window.orgConfirmAdd    = confirmAdd;

        // ── Colors ──
        const avColors    = { navy:'#eef1ff', sky:'#E6F1FB', teal:'#E1F5EE', warm:'#FAEEDA' };
        const avTextColors = { navy:'var(--accent)', sky:'#0C447C', teal:'#085041', warm:'#633806' };

        // ── Set date ──
        const sub = document.getElementById('orgDateSub');
        if (sub) {
            const d = new Date();
            sub.textContent = 'Factory workforce structure — ' +
                d.toLocaleDateString('en-US', { weekday:'long', year:'numeric', month:'long', day:'numeric' });
        }

        // ── Load Planner Groups ──
        fetch('/MasterData/GetPlannerGroups')
            .then(r => r.json())
            .then(data => {
                const el = document.getElementById('pgCards');
                if (!el) return;
                el.innerHTML = data.map(p => `
                    <div class="stat-card fade-in" id="pg${p.id}" onclick="clickPg(${p.id})" style="pointer-events:auto">
                        <div class="stat-icon" style="background:${avColors[p.color]}">
                            <i class="bi bi-people-fill" style="color:${avTextColors[p.color]}"></i>
                        </div>
                        <div class="stat-value" style="font-size:1.4rem; color:${avTextColors[p.color]}">${p.code}</div>
                        <div class="stat-label">${p.name}</div>
                        <span class="stat-badge" style="background:${avColors[p.color]}; color:${avTextColors[p.color]}">${p.sub}</span>
                    </div>`).join('');
            })
            .catch(() => {
                const el = document.getElementById('pgCards');
                if (el) el.innerHTML = `<div style="color:var(--overdue); padding:20px">Failed to load groups</div>`;
            });

        // ── Click PG ──
        window.clickPg = function(id) {
            selPg = id; selPlan = null; selWc = null;

            document.querySelectorAll('#pgCards .stat-card').forEach(c => c.style.outline = 'none');
            const el = document.getElementById('pg' + id);
            if (el) el.style.outline = '2px solid var(--accent)';

            const lvl2 = document.getElementById('lvl2');
            const lvl3 = document.getElementById('lvl3');
            lvl3.style.display = 'none';
            document.getElementById('planCards').innerHTML = `<div class="loading"><div class="spinner-border spinner-border-sm"></div></div>`;
            lvl2.style.display = '';

            fetch(`/MasterData/GetPlanners?pgId=${id}`)
                .then(r => r.json())
                .then(data => {
                    const pc = document.getElementById('planCards');
                    if (!pc) return;
                    pc.innerHTML = data.map(p => `
                        <div class="stat-card fade-in" id="plan${p.id}" onclick="clickPlan(${p.id})" style="pointer-events:auto">
                            <div class="stat-icon" style="background:${avColors[p.color]}">
                                <i class="bi bi-person-fill" style="color:${avTextColors[p.color]}"></i>
                            </div>
                            <div class="stat-value" style="font-size:1.2rem; color:${avTextColors[p.color]}">${p.av}</div>
                            <div class="stat-label">${p.name}</div>
                            <span class="stat-badge" style="background:${avColors[p.color]}; color:${avTextColors[p.color]}">${p.role}</span>
                        </div>`).join('');
                });

            setBc(id, null);
        };

        // ── Click Planner ──
        window.clickPlan = function(id) {
            selPlan = id; selWc = null;

            document.querySelectorAll('#planCards .stat-card').forEach(c => c.style.outline = 'none');
            const el = document.getElementById('plan' + id);
            if (el) el.style.outline = '2px solid var(--accent)';

            const lvl3 = document.getElementById('lvl3');
            document.getElementById('wcGrid').innerHTML = `<div class="loading" style="grid-column:1/-1"><div class="spinner-border spinner-border-sm"></div></div>`;
            lvl3.style.display = '';

            fetch(`/MasterData/GetWorkCenters?plannerId=${id}`)
                .then(r => r.json())
                .then(wcs => {
                    if (!wcs.length) {
                        document.getElementById('wcGrid').innerHTML = `
                            <div class="card-box" style="grid-column:1/-1; text-align:center; color:var(--muted); padding:40px">
                                <i class="bi bi-building" style="font-size:2rem; display:block; margin-bottom:8px; opacity:.3"></i>No work centers
                            </div>`;
                        return;
                    }
                    Promise.all(wcs.map(wc =>
                        fetch(`/MasterData/GetWorkers?wcId=${wc.id}`)
                            .then(r => r.json())
                            .then(workers => ({ wc, workers }))
                    )).then(results => {
                        const grid = document.getElementById('wcGrid');
                        if (grid) grid.innerHTML = results.map(({ wc, workers }) => buildWcCard(wc, workers)).join('');
                    });
                });

            fetch(`/MasterData/GetPlanners?pgId=${selPg}`)
                .then(r => r.json())
                .then(data => setBc(selPg, data.find(p => p.id === id)));
        };

        // ── Build WC Card ──
        function buildWcCard(wc, workers) {
            const rows = workers.length
                ? workers.map(w => buildWorkerRow(wc.id, w)).join('')
                : `<div class="kanban-empty"><i class="bi bi-people"></i>No workers yet</div>`;

            return `
                <div class="card-box fade-in" id="sec${wc.id}">
                    <div class="card-title">
                        <div style="display:flex; align-items:center; gap:8px">
                            <div style="width:28px; height:28px; background:var(--bg); border:1px solid var(--border); border-radius:7px; display:flex; align-items:center; justify-content:center">
                                <i class="bi bi-building" style="color:var(--muted); font-size:0.78rem"></i>
                            </div>
                            <div>
                                <div>${wc.name}</div>
                                <div style="font-size:0.72rem; color:var(--muted); font-weight:400">${wc.type}</div>
                            </div>
                        </div>
                        <div style="display:flex; align-items:center; gap:8px">
                            <span class="kanban-count" id="cnt${wc.id}">${workers.length}</span>
                            <button class="btn-new" style="padding:6px 12px; font-size:0.75rem" onclick="openWorkerModal(${wc.id}, '${wc.name.replace(/'/g,"\\'")}')">
                                <i class="bi bi-person-plus"></i> Add
                            </button>
                        </div>
                    </div>
                    <div id="wklist${wc.id}">${rows}</div>
                    <button class="btn-add-inline" onclick="openWorkerModal(${wc.id}, '${wc.name.replace(/'/g,"\\'")}')">
                        <i class="bi bi-plus"></i> Add more workers
                    </button>
                </div>`;
        }

        function buildWorkerRow(wcId, w) {
            return `
                <div class="task-item" id="wkrow${wcId}_${w.id}">
                    <div class="task-check">${w.av}</div>
                    <div style="flex:1; min-width:0">
                        <div class="task-name">${w.name}</div>
                        <div class="task-date">${w.role}</div>
                    </div>
                    <button class="del-btn" onclick="removeWorker(${wcId}, ${w.id})">
                        <i class="bi bi-x" style="font-size:0.8rem"></i>
                    </button>
                </div>`;
        }

        // ── Remove Worker ──
        window.removeWorker = function(wcId, workerId) {
            fetch('/MasterData/RemoveWorker', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ wcId, workerId })
            }).then(r => r.json()).then(res => {
                if (res.success) {
                    document.getElementById(`wkrow${wcId}_${workerId}`)?.remove();
                    const cnt = document.getElementById('cnt' + wcId);
                    if (cnt) cnt.textContent = parseInt(cnt.textContent) - 1;
                }
            });
        };

        // ── Open Modal ──
        window.openWorkerModal = function(wcId, wcName) {
            selWc = wcId; mSel = [];
            document.getElementById('modalSub').textContent = `Assign to ${wcName}`;
            document.getElementById('workerSearch').value = '';
            document.getElementById('workerModalList').innerHTML = `<div class="loading"><div class="spinner-border spinner-border-sm"></div></div>`;
            document.getElementById('selCount').textContent = '0 selected';

            fetch(`/MasterData/GetAvailableWorkers?wcId=${wcId}`)
                .then(r => r.json())
                .then(data => { allAvail = data; renderModalList(data); });

            const modalEl = document.getElementById('addWorkerModal');
            const modal   = bootstrap.Modal.getOrCreateInstance(modalEl);
            modal.show();
        };

        function renderModalList(list) {
            document.getElementById('workerModalList').innerHTML = list.length
                ? list.map(w => `
                    <div class="task-item" id="mi${w.id}" onclick="orgToggleSel(${w.id})"
                         style="cursor:pointer; padding:10px; border-radius:10px; border:1px solid ${mSel.includes(w.id) ? 'var(--accent)' : 'var(--border)'}; background:${mSel.includes(w.id) ? '#eef1ff' : 'transparent'}; margin-bottom:4px">
                        <div style="width:18px; height:18px; border-radius:4px; border:1.5px solid ${mSel.includes(w.id) ? 'var(--accent)' : 'var(--border)'}; background:${mSel.includes(w.id) ? 'var(--accent)' : 'transparent'}; display:flex; align-items:center; justify-content:center; flex-shrink:0">
                            ${mSel.includes(w.id) ? '<i class="bi bi-check" style="color:white; font-size:0.65rem"></i>' : ''}
                        </div>
                        <div class="task-check" style="font-size:0.6rem">${w.av}</div>
                        <div style="flex:1">
                            <div class="task-name">${w.name}</div>
                            <div class="task-date">${w.role}</div>
                        </div>
                    </div>`).join('')
                : `<div class="kanban-empty"><i class="bi bi-people"></i>No available workers</div>`;
            document.getElementById('selCount').textContent = `${mSel.length} selected`;
        }

        window.orgToggleSel = function(id) {
            const idx = mSel.indexOf(id);
            if (idx > -1) mSel.splice(idx, 1); else mSel.push(id);
            const q = document.getElementById('workerSearch').value.toLowerCase();
            renderModalList(allAvail.filter(w => !q || w.name.toLowerCase().includes(q) || w.role.toLowerCase().includes(q)));
        };

        function filterWorkers() {
            const q = document.getElementById('workerSearch').value.toLowerCase();
            renderModalList(allAvail.filter(w => !q || w.name.toLowerCase().includes(q) || w.role.toLowerCase().includes(q)));
        }

        // ── Confirm Add ──
        function confirmAdd() {
            if (!mSel.length) return;
            fetch('/MasterData/AddWorker', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ wcId: selWc, workerIds: mSel })
            }).then(r => r.json()).then(res => {
                if (res.success) {
                    const added     = allAvail.filter(w => mSel.includes(w.id));
                    const container = document.getElementById('wklist' + selWc);
                    added.forEach(w => container.insertAdjacentHTML('beforeend', buildWorkerRow(selWc, w)));
                    const cnt = document.getElementById('cnt' + selWc);
                    if (cnt) cnt.textContent = parseInt(cnt.textContent) + added.length;
                    bootstrap.Modal.getInstance(document.getElementById('addWorkerModal'))?.hide();
                }
            });
        }

        // ── Breadcrumb ──
        function setBc(pgId, planner) {
            const pgEl   = document.getElementById('pg' + pgId);
            const pgName = pgEl?.querySelector('.stat-label')?.textContent || 'Group';
            let html = `<span class="bc-item" onclick="orgResetAll()">All Groups</span>`;
            html    += `<span class="bc-sep">›</span>`;
            html    += `<span class="bc-item ${!planner ? 'active' : ''}" onclick="clickPg(${pgId})">${pgName}</span>`;
            if (planner) {
                html += `<span class="bc-sep">›</span>`;
                html += `<span class="bc-item active">${planner.name}</span>`;
            }
            const bc = document.getElementById('bc');
            if (bc) bc.innerHTML = html;
        }

        window.orgResetAll = function() {
            selPg = null; selPlan = null; selWc = null;
            document.querySelectorAll('.stat-card').forEach(c => c.style.outline = 'none');
            document.getElementById('lvl2').style.display = 'none';
            document.getElementById('lvl3').style.display = 'none';
            const bc = document.getElementById('bc');
            if (bc) bc.innerHTML = `<span class="bc-item active">All Groups</span>`;
        };

    })(); // end IIFE
</script>
