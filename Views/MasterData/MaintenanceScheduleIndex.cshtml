@{
    ViewBag.Title = "MasterData";
    Layout = "~/Views/Shared/_MasterDataLayout.cshtml";

}

    <style>
        :root {
            --bg: #f4f6fb;
            --surface: #ffffff;
            --border: #e8ecf4;
            --text: #1a1f36;
            --muted: #8892a4;
            --accent: #4f6ef7;
            --todo: #94a3b8;
            --inprogress: #4f6ef7;
            --done: #22c55e;
            --overdue: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 240px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 28px 20px;
        }

        .logo {
            font-size: 1.2rem;
            font-weight: 700;
            color: var(--accent);
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 36px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: var(--accent);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 10px;
            color: var(--muted);
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            margin-bottom: 4px;
        }

            .nav-item:hover {
                background: #f0f3ff;
                color: var(--accent);
            }

            .nav-item.active {
                background: #eef1ff;
                color: var(--accent);
                font-weight: 600;
            }

        .nav-section {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 20px 0 8px 14px;
        }

        /* Main */
    .page-content {
        padding: 28px;
    }

        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .page-title {
            font-size: 1.6rem;
            font-weight: 700;
        }

        .page-sub {
            color: var(--muted);
            font-size: 0.9rem;
            margin-top: 4px;
        }

        .btn-new {
            background: var(--accent);
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: opacity 0.2s;
        }

            .btn-new:hover {
                opacity: 0.85;
            }

        /* Stat Cards */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
        pointer-events: auto;
        cursor: pointer;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 22px 24px;
            position: relative !important;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            animation: fadeUp 0.5s ease both;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(79,110,247,0.1);
            }

            .stat-card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .stat-card:nth-child(2) {
                animation-delay: 0.1s;
            }

            .stat-card:nth-child(3) {
                animation-delay: 0.15s;
            }

            .stat-card:nth-child(4) {
                animation-delay: 0.2s;
            }

        .stat-card * {
            pointer-events: auto;
        }


        .stat-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-bottom: 14px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            font-family: 'DM Mono', monospace;
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-label {
            font-size: 0.85rem;
            color: var(--muted);
            font-weight: 500;
        }

        .stat-badge {
            position: absolute !important;
            top: 20px;
            right: 20px;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 20px;
        }

        /* Bottom Grid */
        .bottom-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 20px;
        }

        .card-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            animation: fadeUp 0.5s ease both;
            animation-delay: 0.3s;
            display: flex;
            flex-direction: column;
            height: 420px;
        }

        .card-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .card-title span {
                color: var(--muted);
                font-size: 0.8rem;
                font-weight: 500;
            }

        /* Donut */
        .donut-wrap {
            position: relative;
            width: 200px;
            margin: 0 auto 24px;
        }

        .donut-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .donut-total {
            font-size: 1.8rem;
            font-weight: 700;
            font-family: 'DM Mono', monospace;
        }

        .donut-sub {
            font-size: 0.75rem;
            color: var(--muted);
        }

        .legend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
        }

            .legend-item:last-child {
                border-bottom: none;
            }

        .legend-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .legend-left {
            display: flex;
            align-items: center;
        }

        .legend-count {
            font-weight: 600;
            font-family: 'DM Mono', monospace;
        }

        /* Task List */
        .task-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.88rem;
            transition: background 0.15s;
        }

            .task-item:last-child {
                border-bottom: none;
            }

        .task-check {
            width: 18px;
            height: 18px;
            border-radius: 5px;
            border: 2px solid var(--border);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
        }

            .task-check.done {
                background: var(--done);
                border-color: var(--done);
                color: white;
            }

            .task-check.inprogress {
                border-color: var(--inprogress);
            }

        .task-name {
            flex: 1;
            font-weight: 500;
        }

            .task-name.done-text {
                text-decoration: line-through;
                color: var(--muted);
            }

        .task-tag {
            font-size: 0.72rem;
            font-weight: 600;
            padding: 3px 9px;
            border-radius: 20px;
        }

        .tag-todo {
            background: #f1f5f9;
            color: var(--todo);
        }

        .tag-inprogress {
            background: #eef1ff;
            color: var(--inprogress);
        }

        .tag-done {
            background: #f0fdf4;
            color: var(--done);
        }

        .tag-overdue {
            background: #fef2f2;
            color: var(--overdue);
        }

        .task-date {
            color: var(--muted);
            font-size: 0.78rem;
            font-family: 'DM Mono', monospace;
        }

        .chart-container{
    margin-top:20px;
}

.vchart{
    display:flex;
    align-items:flex-end;
    justify-content:space-around;
    height:200px;
}

.bar-item{
    display:flex;
    flex-direction:column;
    align-items:center;
}

.bar{
    width:32px;
    background:#2563eb;
    border-radius:6px 6px 0 0;
}

.bar-label{
    margin-top:6px;
    font-size:0.75rem;
    color:#6b7280;
}

.pagination-circle{
    display:flex;
    justify-content:center;
    gap:10px;
    padding-bottom: 5px;
   
}

.page-btn{
    width:34px;
    height:34px;
    border-radius:50%;
    border:1px solid #e5e7eb;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:0.85rem;
    color:#6b7280;
    cursor:pointer;
}

.page-btn.active{
    background:#2563eb;
    color:white;
    border:none;
}

    .btn-gen {
        background: #7C3AED;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity 0.2s;
    }
        
    /* ===== Loading ===== */
.loading-wrapper {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 30px;
}

/* Card */
.loading-card {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #4F46E5;
    font-weight: 500;
}

/* Spinner */
.spinner {
    width: 22px;
    height: 22px;
    border: 3px solid #E2E8F0;
    border-top: 3px solid #4F46E5;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
}

@@keyframes spin {
    to { transform: rotate(360deg); }
}

/* ===== Skeleton ===== */
.skeleton {
    display: flex;
    flex-direction: column;
    gap: 10px;
}

.sk-line {
    height: 12px;
    background: linear-gradient(
        90deg,
        #E2E8F0 25%,
        #F1F5F9 50%,
        #E2E8F0 75%
    );
    border-radius: 6px;
    animation: shimmer 1.2s infinite;
}

.sk-line.w-40 { width: 40%; }
.sk-line.w-60 { width: 60%; }

@@keyframes shimmer {
    0% { background-position: -200px 0; }
    100% { background-position: 200px 0; }
}

/* ===== Error ===== */
.error-box {
    padding: 30px;
    text-align: center;
    color: #EF4444;
}

.error-box button {
    margin-top: 10px;
    padding: 6px 14px;
    border: none;
    background: #4F46E5;
    color: #fff;
    border-radius: 6px;
    cursor: pointer;
}
       
</style>


    <!-- Main -->

    <div class="page-content">
        <div class="page-header">
            <div>
                <div class="page-title">Maintenance Schedule Management</div>
                <div class="page-sub">Overview of Maintenance Schedule — @DateTime.Now.ToString("dddd, MMMM d yyyy")</div>
            </div>
        </div>

        <!-- Stat Cards -->
        <div class="stat-grid">
            <div class="stat-card" data-url="@Url.Action("StandardsIndex", "MasterData")">
                <div class="stat-icon" style="background:#eef2ff"><i class="bi bi-file-earmark-check" style="color:#2563eb"></i></div>
                <div class="stat-value" style="color:#2563eb" id="totalStandards">0</div>
                <div class="stat-label">Total Standards</div>
                <span class="stat-badge" style="background:#eef2ff;color:#2563eb">Standards</span>
            </div>

        <div class="stat-card" data-url="@Url.Action("IndicatorsIndex", "MasterData")">
                <div class="stat-icon" style="background:#f3e8ff"><i class="bi bi-activity" style="color:#a855f7"></i></div>
                <div class="stat-value" style=" color:#a855f7" id="totalIndicators">0</div>
                <div class="stat-label">Total Indicators</div>
                <span class="stat-badge" style="background:#f3e8ff; color:#a855f7">Indicators</span>
            </div>

        <div class="stat-card" data-url="@Url.Action("ControlItemsIndex", "MasterData")">
                <div class="stat-icon" style="background:#fef3c7"><i class="bi bi-list-check" style="color:#f59e0b"></i></div>
                <div class="stat-value" style="color:#f59e0b" id="totalControlItems">0</div>
                <div class="stat-label">Total Control Items</div>
                <span class="stat-badge" style="background:#fef3c7;color:#f59e0b">Control Items</span>
            </div>

        <div class="stat-card" data-url="@Url.Action("ControlItemsIndex", "MasterData")">
                <div class="stat-icon" style="background:#ecfdf5"><i class="bi bi-calendar2-check" style="color:#10b981"></i></div>
            <div class="stat-value" style="color:#10b981" id="totalSchedules">0</div>
                <div class="stat-label">Total Schedules</div>
                <span class="stat-badge" style="background:#ecfdf5;color:#10b981">Schedules</span>
            </div>


        </div>

    <div class="bottom-grid">

        <!-- แถว 1: Asset Type + Standard -->
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">

            <!-- Chart 1: Controls by Asset Type -->
            <div class="card-box" style="animation-delay:0.35s">
                <div class="card-title">Controls by asset type</div>
                <div class="chart-container">
                    <div style="display: flex; align-items: center; justify-content: center; gap: 20px; width: 100%;">

                        <div style="width: 180px; height: 180px; flex-shrink: 0;">
                            <canvas id="chartAssetBottom"></canvas>
                        </div>

                        <div id="legendAssetBottom"
                             style="display: flex; flex-direction: column; gap: 8px; font-size: 10px; color: var(--color-text-secondary); max-height: 180px; overflow-y: auto;">
                        </div>

                    </div>
                </div>
            </div>

            <!-- Chart 2: Controls by Standard -->
            <div class="card-box" style="animation-delay:0.4s">
                <div class="card-title">Controls by standard</div>
                <div class="chart-container">
                    <div style="position:relative;width:100%;height:220px;">
                        <canvas id="chartStandardBottom"></canvas>
                    </div>
                </div>
            </div>

        </div>

        <!-- แถว 2: Schedules by Indicator (เต็มแถว) -->
        <div class="card-box" style="animation-delay:0.45s;margin-top:16px;">
            <div class="card-title">Schedules by indicator</div>
            <div class="chart-container">
                <div style="position:relative;width:100%;height:260px;">
                    <canvas id="chartIndicatorBottom"></canvas>
                </div>
            </div>
        </div>

    </div>



    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script src="~/js/tabLoader.js"></script>
<script src="~/js/maintenanceschedule.js"></script>

<script>
        // ====================================================
    // Init
    // ====================================================
    async function _initMasterData() {
        console.log('📡 Loading master data...');
        await MaintenanceTree.initMasterData();
        await _loadStatistics();
    }

    // กรณีโหลดตรง
    document.addEventListener('DOMContentLoaded', async () => {
        console.log(' Initializing System...');
        try {
            await _initMasterData();
            console.log('Standard Ready!');
        } catch (error) {
            console.error(' Initialization Error:', error);
        }
    });

    // กรณีโหลดผ่าน tab — ป้องกัน run ซ้ำถ้า DOMContentLoaded ยิงไปแล้ว
    document.addEventListener('tabContentReady', async () => {
        try {
            await _initMasterData();
        } catch (error) {
            console.error('❌ Tab Init Error:', error);
        }
    });

    // ====================================================
    // Stat card click → navigate via tabLoader
    // ====================================================
    (function () {
        document.addEventListener('click', function (e) {
            const card = e.target.closest('.stat-card');
            const url  = card?.getAttribute('data-url');
            if (!url) return;

            const activePanel = document.querySelector('.tab-panel.active');
            if (activePanel && typeof loadTabContent === 'function') {
                const label = card.querySelector('.stat-label')?.innerText ?? '';
                activePanel.innerHTML = `
                    <div style="padding:40px;display:flex;align-items:center;gap:10px;color:var(--muted)">
                        <div class="spinner-border spinner-border-sm"></div> Switching to ${label}...
                    </div>`;
                loadTabContent(url, activePanel);
            } else {
                window.location.href = url;
            }
        });
    })();


    // ====================================================
    // Charts
    // ====================================================
    function createControlsByAssetTypeBottomChart(data) {
        const ctx = document.getElementById('chartAssetBottom')?.getContext('2d');
        if (!ctx) return;

        const colors = ['#378ADD', '#1D9E75', '#EF9F27'];
        const total  = data.reduce((s, d) => s + d.count, 0);

        const legend = document.getElementById('legendAssetBottom');
        if (legend) {
            legend.innerHTML = data.map((d, i) => `
                <span style="display:flex;align-items:center;gap:5px;">
                    <span style="width:10px;height:10px;border-radius:2px;background:${colors[i]};flex-shrink:0"></span>
                    ${d.assetType} — ${((d.count / total) * 100).toFixed(1)}%
                </span>
            `).join('');
        }

        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: data.map(d => d.assetType),
                datasets: [{
                    data: data.map(d => d.count),
                    backgroundColor: colors,
                    borderWidth: 2, borderColor: 'transparent', hoverOffset: 6
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false, cutout: '62%',
                plugins: {
                    legend: { display: false },
                    tooltip: { callbacks: { label: ctx => ` ${ctx.label}: ${ctx.parsed.toLocaleString()}` } }
                }
            }
        });
    }

    function createSchedulesByIndicatorBottomChart(data) {
        const ctx = document.getElementById('chartIndicatorBottom')?.getContext('2d');
        if (!ctx) return;

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: data.map(d => d.indicator),
                datasets: [{
                    data: data.map(d => d.count),
                    backgroundColor: '#1D9E75', borderRadius: 3, borderSkipped: false
                }]
            },
            options: {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { grid: { display: false }, ticks: { font: { size: 10 }, autoSkip: false, maxRotation: 45 } },
                    y: { ticks: { callback: v => v >= 1000 ? (v / 1000).toFixed(1) + 'k' : v } }
                }
            }
        });
    }

    function createByStandardBottomChart(data) {
        const ctx = document.getElementById('chartStandardBottom')?.getContext('2d');
        if (!ctx) return;

        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: data.map(d => d.standard),
                datasets: [{
                    data: data.map(d => d.count),
                    backgroundColor: '#378ADD', borderRadius: 4, borderSkipped: false
                }]
            },
            options: {
                indexAxis: 'y', responsive: true, maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    x: { ticks: { callback: v => v >= 1000 ? (v / 1000).toFixed(1) + 'k' : v } },
                    y: { grid: { display: false }, ticks: { font: { size: 11 } } }
                }
            }
        });
    }

</script>

