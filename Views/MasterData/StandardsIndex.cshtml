   <script>
    // ประกาศข้างนอก — ใช้ได้ทั้ง DOMContentLoaded และ tabContentReady
    async function _initMasterData() {
        console.log('📡 Loading master data...');
        await MaintenanceTree.initMasterData();
    }

    // กรณีโหลดตรง
    document.addEventListener('DOMContentLoaded', async () => {
        console.log('🚀 Initializing System...');
        try {
            await _initMasterData();
            console.log('✅ Standard Ready!');
        } catch (error) {
            console.error('❌ Initialization Error:', error);
        }
    });

    // กรณีโหลดผ่าน tab
    document.addEventListener('tabContentReady', async () => {
        try {
            await _initMasterData();
        } catch (error) {
            console.error('❌ Tab Init Error:', error);
        }
    });

    (function () {
        document.addEventListener('click', function (e) {
            // 1. หาเป้าหมายที่ถูกคลิก (รองรับทั้ง Card และปุ่ม Back)
            const target = e.target.closest('.stat-card, .back-btn');
            if (!target) return; // ถ้าไม่ได้คลิกโดนปุ่มหรือการ์ด ให้จบการทำงาน

            const url = target.getAttribute('data-url');
            if (!url) return;

            const activePanel = document.querySelector('.tab-panel.active');

            // ตรวจสอบว่ามี Tab System หรือไม่
            if (activePanel && typeof loadTabContent === 'function') {
                // 2. ดึงข้อความมาแสดงตอน Loading (ถ้าไม่มี .stat-label ให้ใช้คำว่า 'Previous Page')
                const labelNode = target.querySelector('.stat-label');
                const labelText = labelNode ? labelNode.innerText : 'Previous Page';

                activePanel.innerHTML = `
                    <div style="padding:40px;display:flex;align-items:center;gap:10px;color:var(--muted)">
                        <div class="spinner-border spinner-border-sm"></div> Switching to ${labelText}...
                    </div>`;

                // 3. โหลด Content
                loadTabContent(url, activePanel);
            } else {
                // กรณีไม่มีระบบ Tab ให้เปลี่ยนหน้าปกติ
                window.location.href = url;
            }
        });
    })();
</script>




    
    