<script>

    // ====================================================================
        // INITIALIZATION
        // ====================================================================
        document.addEventListener('DOMContentLoaded', async () => {
    console.log('🚀 Initializing System...');
    try {
        _initModals();
        _initMatrixButtons();
        _initMatrixTab();
        _initModalReset();
        // _initPagination();
        await _initTree();
        console.log('✅ System Ready!');
    } catch (error) {
        console.error('❌ Initialization Error:', error);
    }
});
 
// ══════════════════════════════════════════════════════════════════
//  Private init functions — แต่ละ section แยกชัดเจน
// ══════════════════════════════════════════════════════════════════
 
// ── 1. Modals ──────────────────────────────────────────────────────
function _initModals() {
    const modalEl = document.getElementById('nodeDetailModal');
    if (!modalEl) return;
    window.nodeDetailModal = bootstrap.Modal.getOrCreateInstance(modalEl);
    console.log('✅ Node Detail Modal initialized');
}
 
// ── 2. Matrix action buttons ───────────────────────────────────────
function _initMatrixButtons() {
    document.getElementById('btnReloadNodeMatrix')
        ?.addEventListener('click', () => reloadNodeMatrix());
 
    document.getElementById('btnClearNodeSchedules')
        ?.addEventListener('click', () => clearAllSchedulesForNode());
}
 
// ── 3. Matrix tab ──────────────────────────────────────────────────
function _initMatrixTab() {
    document.getElementById('matrix-tab')
        ?.addEventListener('shown.bs.tab', _onMatrixTabShown);
}
 
async function _onMatrixTabShown() {
    console.log('📊 Matrix tab activated');
 
    // โหลดครั้งเดียว — ป้องกัน double load ด้วย flag
    const nodeId = window.currentNode?.id;
    if (window.nodeMatrixLoaded || !nodeId) return;
 
    window.nodeMatrixLoaded = true;
    try {
        await loadMatrixData(nodeId, false, 'node');
    } catch (err) {
        console.error('❌ Matrix load failed:', err);
        window.nodeMatrixLoaded = false; // reset ให้ retry ได้
        Swal.fire('Error', 'Failed to load maintenance matrix', 'error');
    }
}
 
// ── 4. Modal reset on hidden ────────────────────────────────────────
function _initModalReset() {
    document.getElementById('nodeDetailModal')
        ?.addEventListener('hidden.bs.modal', _onModalHidden);
}
 
function _onModalHidden() {
    _resetMatrixState();
    _resetMatrixTables();
    _resetTabBadges();
    _resetActiveTab();
    _resetQuickForms();
    _deselectTreeNodes();
    console.log('🔄 Modal closed, state reset');
}
 
function _resetMatrixState() {
    window.nodeMatrixLoaded = false;
    window.currentNode      = null;
}
 
function _resetMatrixTables() {
    const targets = [
        { id: 'matrix-header-node-me', content: MATRIX_DEFAULT_HEADER },
        { id: 'matrix-header-node-ee', content: MATRIX_DEFAULT_HEADER },
        { id: 'matrix-body-node-me',   content: MATRIX_DEFAULT_BODY   },
        { id: 'matrix-body-node-ee',   content: MATRIX_DEFAULT_BODY   },
    ];
    targets.forEach(({ id, content }) => {
        const el = document.getElementById(id);
        if (el) el.innerHTML = content;
    });
}
 
function _resetTabBadges() {
    ['me-count-node', 'ee-count-node'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.textContent = '0';
    });
}
 
function _resetActiveTab() {
    const meTab = document.getElementById('me-tab-node');
    if (meTab && !meTab.classList.contains('active')) {
        bootstrap.Tab.getOrCreateInstance(meTab).show();
    }
}
 
function _resetQuickForms() {
    ['quickAttrForm', 'quickLinkForm'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.style.display = 'none';
    });
}
 
function _deselectTreeNodes() {
    document.querySelectorAll('.tree-node')
        .forEach(el => el.classList.remove('selected-node'));
}
 
// ── 5. Pagination ───────────────────────────────────────────────────
function _initPagination() {
    // โหลดผ่าน @@section Scripts แล้ว — เรียกตรงได้เลย ไม่ต้องตรวจ typeof
    initPaginationOri();
    console.log('✅ Pagination initialized');
}
 
// ── 6. Tree ─────────────────────────────────────────────────────────
async function _initTree() {
    // โหลดผ่าน @@section Scripts แล้ว — เรียกตรงได้เลย ไม่ต้องตรวจ typeof
    console.log('📡 Loading tree data...');
    await Tree.reloadTree();
}

    // ── File Select ──
    function onFileSelect(input) {
        if (input.files && input.files[0]) showPreview(input.files[0]);
    }

    function showPreview(file) {
        document.getElementById('dropZone').style.display   = 'none';
        document.getElementById('filePreview').style.display = '';
        document.getElementById('fileName').textContent = file.name;
        document.getElementById('fileSize').textContent = (file.size / 1024).toFixed(1) + ' KB';
    }

    function clearFile() {
        document.getElementById('fileInput').value           = '';
        document.getElementById('filePreview').style.display = 'none';
        document.getElementById('dropZone').style.display    = '';
    }

    // ── Drag & Drop ──
    function onDragOver(e) {
        e.preventDefault();
        document.getElementById('dropZone').style.borderColor = 'var(--accent)';
        document.getElementById('dropZone').style.background  = 'var(--accent-light)';
    }

    function onDragLeave(e) {
        document.getElementById('dropZone').style.borderColor = 'var(--border)';
        document.getElementById('dropZone').style.background  = 'var(--bg)';
    }

    function onDrop(e) {
        e.preventDefault();
        onDragLeave(e);
        const file = e.dataTransfer.files[0];
        if (file) {
            // ใส่ไฟล์เข้า input
            const dt = new DataTransfer();
            dt.items.add(file);
            document.getElementById('fileInput').files = dt.files;
            showPreview(file);
        }
    }

    // ── Reset form ตอนปิด Modal ──
    document.getElementById('insertModal').addEventListener('hidden.bs.modal', () => {
        document.getElementById('insertForm').reset();
        clearFile();
    });
</script>

