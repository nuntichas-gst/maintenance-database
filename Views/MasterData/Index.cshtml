@{
    ViewBag.Title = "MasterData";
    Layout = "~/Views/Shared/_MasterDataLayout.cshtml";
    
}

    <style>
        :root {
            --bg: #f4f6fb;
            --surface: #ffffff;
            --border: #e8ecf4;
            --text: #1a1f36;
            --muted: #8892a4;
            --accent: #4f6ef7;
            --todo: #94a3b8;
            --inprogress: #4f6ef7;
            --done: #22c55e;
            --overdue: #ef4444;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
        }

        

        .logo {
            font-size: 1.2rem;
            font-weight: 700;
            color: #003A8F;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 36px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: #003A8F;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 10px;
            color: var(--muted);
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            margin-bottom: 4px;
        }

            .nav-item:hover {
                background: #f0f3ff;
                color: #003A8F;
            }

            .nav-item.active {
                background: #eef1ff;
                color: #003A8F;
                font-weight: 600;
            }

        .nav-section {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 20px 0 8px 14px;
        }

        /* Main */


        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 32px;
        }

        .page-title {
            font-size: 1.6rem;
            font-weight: 700;
        }

        .page-sub {
            color: var(--muted);
            font-size: 0.9rem;
            margin-top: 4px;
        }

        .btn-new {
            background: #003A8F;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 10px;
            font-family: 'DM Sans', sans-serif;
            font-weight: 600;
            font-size: 0.9rem;
            cursor: pointer;
            transition: opacity 0.2s;
        }

            .btn-new:hover {
                opacity: 0.85;
            }

        /* Stat Cards */
        .stat-grid {
            display: grid;
            grid-template-columns: repeat(4, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 22px 24px;
            position: relative !important;
            overflow: hidden;
            transition: transform 0.2s, box-shadow 0.2s;
            animation: fadeUp 0.5s ease both;
        }

            .stat-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 24px rgba(79,110,247,0.1);
            }

            .stat-card:nth-child(1) {
                animation-delay: 0.05s;
            }

            .stat-card:nth-child(2) {
                animation-delay: 0.1s;
            }

            .stat-card:nth-child(3) {
                animation-delay: 0.15s;
            }

            .stat-card:nth-child(4) {
                animation-delay: 0.2s;
            }

        .stat-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
            margin-bottom: 14px;
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            font-family: 'DM Mono', monospace;
            line-height: 1;
            margin-bottom: 6px;
        }

        .stat-label {
            font-size: 0.85rem;
            color: var(--muted);
            font-weight: 500;
        }

        .stat-badge {
            position: absolute !important;
            top: 20px;
            right: 20px;
            font-size: 0.72rem;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 20px;
        }

        /* Bottom Grid */
        .bottom-grid {
            display: grid;
            gap: 20px;
        }

    /* Bottom Grid */
    .bottom-grid-approve {
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 20px;
    }

        .card-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            animation: fadeUp 0.5s ease both;
            animation-delay: 0.3s;
            margin-bottom: 16px;
        }

        .card-title {
            font-size: 1rem;
            font-weight: 700;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .card-title span {
                color: var(--muted);
                font-size: 0.8rem;
                font-weight: 500;
            }

    .btn-gen {
        background: #7C3AED;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        font-family: 'DM Sans', sans-serif;
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: opacity 0.2s;
    }

        /* Donut */
        .donut-wrap {
            position: relative;
            width: 200px;
            margin: 0 auto 24px;
        }

        .donut-center {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            text-align: center;
        }

        .donut-total {
            font-size: 1.8rem;
            font-weight: 700;
            font-family: 'DM Mono', monospace;
        }

        .donut-sub {
            font-size: 0.75rem;
            color: var(--muted);
        }

        .legend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.85rem;
        }

            .legend-item:last-child {
                border-bottom: none;
            }

        .legend-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            margin-right: 10px;
            flex-shrink: 0;
        }

        .legend-left {
            display: flex;
            align-items: center;
        }

        .legend-count {
            font-weight: 600;
            font-family: 'DM Mono', monospace;
        }

        /* Task List */
        .task-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.88rem;
            transition: background 0.15s;
        }

            .task-item:last-child {
                border-bottom: none;
            }

        .task-check {
            width: 18px;
            height: 18px;
            border-radius: 5px;
            border: 2px solid var(--border);
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.65rem;
        }

            .task-check.done {
                background: var(--done);
                border-color: var(--done);
                color: white;
            }

            .task-check.inprogress {
                border-color: var(--inprogress);
            }

        .task-name {
            flex: 1;
            font-weight: 500;
        }

            .task-name.done-text {
                text-decoration: line-through;
                color: var(--muted);
            }

        .task-tag {
            font-size: 0.72rem;
            font-weight: 600;
            padding: 3px 9px;
            border-radius: 20px;
        }

        .tag-todo {
            background: #f1f5f9;
            color: var(--todo);
        }

        .tag-inprogress {
            background: #eef1ff;
            color: var(--inprogress);
        }

        .tag-done {
            background: #f0fdf4;
            color: var(--done);
        }

        .tag-overdue {
            background: #fef2f2;
            color: var(--overdue);
        }

        .task-date {
            color: var(--muted);
            font-size: 0.78rem;
            font-family: 'DM Mono', monospace;
        }

        .pagination-wrap {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 12px;
            margin-top: 16px;
        }

            .pagination-wrap button {
                border: 1px solid var(--border);
                background: white;
                padding: 4px 10px;
                border-radius: 6px;
                font-size: 0.8rem;
            }

   
    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    :root {
        --bg: #f4f6fb;
        --surface: #ffffff;
        --border: #e8ecf4;
        --text: #1a1f36;
        --muted: #8892a4;
        --accent: #4f6ef7;
        --done: #22c55e;
        --overdue: #ef4444;
        --me: #4f6ef7;
        --ee: #f59e0b;
    }

    body {
        font-family: 'DM Sans',system-ui,sans-serif;
        background: var(--bg);
        color: var(--text);
        font-size: 13px;
        line-height: 1.5;
    }

    .page {
        padding: 16px 0;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    /* ── Search + actions ── */
    .toolbar {
        display: flex;
        gap: 8px;
        align-items: center;
    }

    .search {
        position: relative;
        flex: 1;
    }

        .search svg {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--muted);
            pointer-events: none;
        }

        .search input {
            width: 100%;
            padding: 10px 14px 10px 38px;
            border-radius: 10px;
            border: 1.5px solid var(--border);
            background: var(--surface);
            font-size: 13px;
            color: var(--text);
            outline: none;
            transition: border-color .15s,box-shadow .15s;
        }

            .search input:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(79,110,247,.1);
            }

    .action-btn {
        padding: 10px 16px;
        border-radius: 10px;
        border: 1.5px solid var(--border);
        background: var(--surface);
        font-size: 12px;
        font-weight: 500;
        color: var(--muted);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
        transition: all .15s;
    }

        .action-btn:hover {
            border-color: var(--accent);
            color: var(--accent);
            background: #f0f3ff;
        }

        .action-btn.danger:hover {
            border-color: var(--overdue);
            color: var(--overdue);
            background: #fff5f5;
        }

    /* ── Meta row ── */
    .meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 2px;
    }

    .meta-count {
        font-size: 12px;
        color: var(--muted);
    }

        .meta-count b {
            color: var(--text);
            font-weight: 600;
        }

    .meta-hint {
        font-size: 11px;
        color: var(--muted);
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .leg-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
    }

    /* ── Asset cards ── */
    .cards {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .card {
        background: var(--surface);
        border: 1.5px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        transition: border-color .15s,box-shadow .15s;
    }

        .card:hover {
            border-color: #c7d2fe;
            box-shadow: 0 2px 12px rgba(79,110,247,.07);
        }

        .card.open {
            border-color: #c7d2fe;
            box-shadow: 0 2px 16px rgba(79,110,247,.08);
        }

    /* card header */
    .card-hdr {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 16px;
        cursor: pointer;
        user-select: none;
    }

    .hdr-arrow {
        width: 22px;
        height: 22px;
        border-radius: 6px;
        border: 1.5px solid var(--border);
        background: var(--bg);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        color: var(--muted);
        font-size: 10px;
        transition: all .18s;
    }

    .card.open .hdr-arrow {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff;
        transform: rotate(90deg);
    }

    .hdr-icon {
        width: 36px;
        height: 36px;
        border-radius: 9px;
        background: #eef1ff;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .hdr-icon svg {
            color: var(--accent);
        }

    .hdr-info {
        flex: 1;
        min-width: 0;
    }

    .hdr-name {
        font-size: 13px;
        font-weight: 600;
        color: var(--text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .hdr-sub {
        font-size: 11px;
        color: var(--muted);
        margin-top: 1px;
    }

    .hdr-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-shrink: 0;
    }

    /* progress pill */
    .prog-pill {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .prog-track {
        width: 80px;
        height: 6px;
        border-radius: 3px;
        background: var(--border);
        overflow: hidden;
    }

    .prog-fill {
        height: 100%;
        border-radius: 3px;
        transition: width .4s;
    }

    .prog-pct {
        font-size: 11px;
        font-weight: 600;
        min-width: 30px;
        text-align: right;
    }

    /* discipline tags on header */
    .disc-tags {
        display: flex;
        gap: 5px;
    }

    .dtag {
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 10px;
        font-weight: 600;
        border: 1.5px solid;
    }

    .dtag-me {
        background: #eef1ff;
        color: var(--me);
        border-color: #c7d2fe;
    }

    .dtag-ee {
        background: #fef3c7;
        color: #b45309;
        border-color: #fde68a;
    }

    /* card body */
    .card-body {
        border-top: 1.5px solid var(--border);
        padding: 16px;
    }

    .disc-section {
        margin-bottom: 14px;
    }

        .disc-section:last-child {
            margin-bottom: 0;
        }

    .disc-hdr {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
    }

    .disc-badge {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 7px;
        font-size: 11px;
        font-weight: 700;
        border: 1.5px solid;
    }

    .badge-me {
        background: #eef1ff;
        color: var(--me);
        border-color: #c7d2fe;
    }

    .badge-ee {
        background: #fef3c7;
        color: #b45309;
        border-color: #fde68a;
    }

    .disc-count {
        font-size: 11px;
        color: var(--muted);
    }

    /* cell grid */
    .cell-grid {
        display: grid;
        grid-template-columns: repeat(11,1fr);
        gap: 5px;
    }

    .cell {
        border-radius: 9px;
        border: 1.5px solid var(--border);
        background: var(--bg);
        padding: 8px 5px 7px;
        text-align: center;
        cursor: pointer;
        transition: border-color .12s,background .12s,transform .1s;
        position: relative;
    }

        .cell:hover {
            border-color: var(--accent);
            background: #eef1ff;
            transform: translateY(-1px);
        }

        .cell.filled {
            background: #f0fdf4;
            border-color: #86efac;
        }

            .cell.filled:hover {
                background: #dcfce7;
                transform: translateY(-1px);
            }

        .cell.editing {
            background: #eef1ff;
            border-color: var(--accent);
            padding: 7px 5px;
            cursor: default;
        }

            .cell.editing:hover {
                transform: none;
            }

    .cell-label {
        font-size: 9px;
        color: var(--muted);
        line-height: 1.2;
        margin-bottom: 5px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .cell-val {
        font-size: 12px;
        font-weight: 700;
        color: #16a34a;
        line-height: 1;
    }

    .cell-empty {
        font-size: 16px;
        color: #d1d5db;
        font-weight: 300;
        line-height: 1;
    }

    .cell-star {
        color: #f59e0b;
        font-size: 8px;
        vertical-align: super;
        line-height: 0;
    }

    /* flash */
    .cell.flash {
        animation: flash 2s ease-out forwards;
    }
    @@keyframes flash {
        0% {
            background: #fef08a;
            border-color: #facc15;
        }

        40% {
            background: #fef9c3;
            border-color: #fde68a;
        }

        100% {
            background: var(--bg);
            border-color: var(--border);
        }
    }

    .cell.filled.flash {
        animation: flashg 2s ease-out forwards;
    }
    @@keyframes flashg {
        0% {
            background: #6ee7b7;
            border-color: #10b981;
        }

        40% {
            background: #a7f3d0;
            border-color: #34d399;
        }

        100% {
            background: #f0fdf4;
            border-color: #86efac;
        }
    }

    /* edit form inside cell */
    .ef {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
    }

    .ef-label {
        font-size: 8px;
        color: var(--accent);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .ef input {
        width: 100%;
        padding: 4px 5px;
        border-radius: 5px;
        border: 1.5px solid var(--accent);
        font-size: 11px;
        font-weight: 600;
        color: var(--text);
        background: #fff;
        outline: none;
        text-align: center;
        box-shadow: 0 0 0 3px rgba(79,110,247,.1);
    }

    .ef-btns {
        display: flex;
        gap: 3px;
        width: 100%;
    }

    .ef-ok {
        flex: 1;
        padding: 3px 0;
        border-radius: 5px;
        font-size: 10px;
        font-weight: 700;
        background: var(--accent);
        color: #fff;
        border: none;
        cursor: pointer;
    }

        .ef-ok:hover {
            background: #3d5ce6;
        }

    .ef-cx {
        padding: 3px 5px;
        border-radius: 5px;
        font-size: 10px;
        background: #fff;
        border: 1.5px solid var(--border);
        color: var(--muted);
        cursor: pointer;
    }

    </style>


    <!-- Main -->
    <div class="page-content">
        <div class="page-header">
            <div>
                <div class="page-title">Asset Hierarchy</div>
                <div class="page-sub">Overview of all hierarchy — @DateTime.Now.ToString("dddd, MMMM d yyyy")</div>
            </div>
            <button class="btn-new" data-bs-toggle="modal" data-bs-target="#insertModal"><i class="bi bi-plus me-1"></i>New Asset</button>
        </div>

        <!-- Stat Cards -->
        <div class="stat-grid">

                <div class="stat-card">
                    <div class="stat-icon" style="background:#eef2ff"><i class="bi bi-diagram-3" style="color:#2563eb"></i></div>
                    <div class="stat-value" style="color:var(--inprogress)" id="stat-line">0</div>
                    <div class="stat-label">Total Lines</div>
                <span class="stat-badge" style="background:#eef2ff;color:#2563eb">Line</span>
                </div>

                <div class="stat-card">
                    <div class="stat-icon" style="background:#eef1ff"><i class="bi bi-gear-wide-connected" style="color:#6b7280"></i></div>
                    <div class="stat-value" style="color:#6b7280" id="stat-machine">0</div>
                    <div class="stat-label">Total Machines</div>
                    <span class="stat-badge" style="background:#eef1ff;color:#6b7280">Machine</span>
                </div>

                <div class="stat-card">
                    <div class="stat-icon" style="background:#f0fdf4"><i class="bi bi-box-seam" style="color:var(--done)"></i></div>
                    <div class="stat-value" style="color:var(--done)" id="stat-unit">0</div>
                    <div class="stat-label">Total Units</div>
                    <span class="stat-badge" style="background:#f0fdf4;color:var(--done)">Units</span>
                </div>

                <div class="stat-card">
                    <div class="stat-icon" style="background:#fef2f2"><i class="bi bi-tools" style="color:var(--overdue)"></i></div>
                    <div class="stat-value" style="color:var(--overdue)" id="stat-part">0</div>
                    <div class="stat-label">Total Parts</div>
                    <span class="stat-badge" style="background:#fef2f2;color:var(--overdue)">Parts</span>
                </div>

       
        </div>

        <!-- Bottom -->
        <div class="bottom-grid">

            <!-- Task List -->
            <div class="card-box" style="animation-delay:0.35s">
                <div class="card-title">
                    Line (Title) <div style="display:flex; align-items:center; gap:8px;">

                        <!-- Search -->
                        <div style="display:flex; align-items:center; gap:6px; background:var(--bg); border:1px solid var(--border); border-radius:8px; padding:5px 10px;">
                            <i class="bi bi-search" style="color:var(--muted); font-size:0.8rem"></i>
                            <input type="text" placeholder="Search..."
                                   onkeyup="filterTable(this.value)"
                                   style="border:none; background:transparent; outline:none; font-size:0.8rem; width:120px; font-family:'DM Sans',sans-serif; color:var(--text)">
                        </div>

                        <!-- Filter -->
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle"
                                    type="button" data-bs-toggle="dropdown"
                                    data-bs-auto-close="outside">
                                <i class="bi bi-funnel"></i> Filter
                            </button>

