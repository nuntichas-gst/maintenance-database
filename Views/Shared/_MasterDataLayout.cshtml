<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Master Data</title>
    
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap-icons/font/bootstrap-icons.css" />

   

    <style>
        
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --bg: #f4f6fb;
            --surface: #ffffff;
            --border: #e8ecf4;
            --text: #1a1f36;
            --muted: #8892a4;
            --accent: #4f6ef7;
            --done: #22c55e;
            --overdue: #ef4444;
            --me: #4f6ef7;
            --ee: #f59e0b;
        }

        body {
            font-family: 'DM Sans',system-ui,sans-serif;
            background: var(--bg);
            color: var(--text);
            font-size: 13px;
            line-height: 1.5;
        }

        .page {
            padding: 16px 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        /* ── Search + actions ── */
        .toolbar {
            display: flex;
            gap: 8px;
            align-items: center;
        }

        .search {
            position: relative;
            flex: 1;
        }

            .search svg {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--muted);
                pointer-events: none;
            }

            .search input {
                width: 100%;
                padding: 10px 14px 10px 38px;
                border-radius: 10px;
                border: 1.5px solid var(--border);
                background: var(--surface);
                font-size: 13px;
                color: var(--text);
                outline: none;
                transition: border-color .15s,box-shadow .15s;
            }

                .search input:focus {
                    border-color: var(--accent);
                    box-shadow: 0 0 0 3px rgba(79,110,247,.1);
                }

        .action-btn {
            padding: 10px 16px;
            border-radius: 10px;
            border: 1.5px solid var(--border);
            background: var(--surface);
            font-size: 12px;
            font-weight: 500;
            color: var(--muted);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            white-space: nowrap;
            transition: all .15s;
        }

            .action-btn:hover {
                border-color: var(--accent);
                color: var(--accent);
                background: #f0f3ff;
            }

            .action-btn.danger:hover {
                border-color: var(--overdue);
                color: var(--overdue);
                background: #fff5f5;
            }

        /* ── Meta row ── */
        .meta {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2px;
        }

        .meta-count {
            font-size: 12px;
            color: var(--muted);
        }

            .meta-count b {
                color: var(--text);
                font-weight: 600;
            }

        .meta-hint {
            font-size: 11px;
            color: var(--muted);
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .legend-item {
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .leg-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        /* ── Asset cards ── */
        .cards {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .card {
            background: var(--surface);
            border: 1.5px solid var(--border);
            border-radius: 14px;
            overflow: hidden;
            transition: border-color .15s,box-shadow .15s;
        }

            .card:hover {
                border-color: #c7d2fe;
                box-shadow: 0 2px 12px rgba(79,110,247,.07);
            }

            .card.open {
                border-color: #c7d2fe;
                box-shadow: 0 2px 16px rgba(79,110,247,.08);
            }

        /* card header */
        .card-hdr {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 13px 16px;
            cursor: pointer;
            user-select: none;
        }

        .hdr-arrow {
            width: 22px;
            height: 22px;
            border-radius: 6px;
            border: 1.5px solid var(--border);
            background: var(--bg);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            color: var(--muted);
            font-size: 10px;
            transition: all .18s;
        }

        .card.open .hdr-arrow {
            background: var(--accent);
            border-color: var(--accent);
            color: #fff;
            transform: rotate(90deg);
        }

        .hdr-icon {
            width: 36px;
            height: 36px;
            border-radius: 9px;
            background: #eef1ff;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .hdr-icon svg {
                color: var(--accent);
            }

        .hdr-info {
            flex: 1;
            min-width: 0;
        }

        .hdr-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .hdr-sub {
            font-size: 11px;
            color: var(--muted);
            margin-top: 1px;
        }

        .hdr-right {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-shrink: 0;
        }

        /* progress pill */
        .prog-pill {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .prog-track {
            width: 80px;
            height: 6px;
            border-radius: 3px;
            background: var(--border);
            overflow: hidden;
        }

        .prog-fill {
            height: 100%;
            border-radius: 3px;
            transition: width .4s;
        }

        .prog-pct {
            font-size: 11px;
            font-weight: 600;
            min-width: 30px;
            text-align: right;
        }

        /* discipline tags on header */
        .disc-tags {
            display: flex;
            gap: 5px;
        }

        .dtag {
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 10px;
            font-weight: 600;
            border: 1.5px solid;
        }

        .dtag-me {
            background: #eef1ff;
            color: var(--me);
            border-color: #c7d2fe;
        }

        .dtag-ee {
            background: #fef3c7;
            color: #b45309;
            border-color: #fde68a;
        }

        /* card body */
        .card-body {
            border-top: 1.5px solid var(--border);
            padding: 16px;
        }

        .disc-section {
            margin-bottom: 14px;
        }

            .disc-section:last-child {
                margin-bottom: 0;
            }

        .disc-hdr {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

        .disc-badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 4px 12px;
            border-radius: 7px;
            font-size: 11px;
            font-weight: 700;
            border: 1.5px solid;
        }

        .badge-me {
            background: #eef1ff;
            color: var(--me);
            border-color: #c7d2fe;
        }

        .badge-ee {
            background: #fef3c7;
            color: #b45309;
            border-color: #fde68a;
        }

        .disc-count {
            font-size: 11px;
            color: var(--muted);
        }

        /* cell grid */
        .cell-grid {
            display: grid;
            grid-template-columns: repeat(11,1fr);
            gap: 5px;
        }

        .cell {
            border-radius: 9px;
            border: 1.5px solid var(--border);
            background: var(--bg);
            padding: 8px 5px 7px;
            text-align: center;
            cursor: pointer;
            transition: border-color .12s,background .12s,transform .1s;
            position: relative;
        }

            .cell:hover {
                border-color: var(--accent);
                background: #eef1ff;
                transform: translateY(-1px);
            }

            .cell.filled {
                background: #f0fdf4;
                border-color: #86efac;
            }

                .cell.filled:hover {
                    background: #dcfce7;
                    transform: translateY(-1px);
                }

            .cell.editing {
                background: #eef1ff;
                border-color: var(--accent);
                padding: 7px 5px;
                cursor: default;
            }

                .cell.editing:hover {
                    transform: none;
                }

        .cell-label {
            font-size: 9px;
            color: var(--muted);
            line-height: 1.2;
            margin-bottom: 5px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .cell-val {
            font-size: 12px;
            font-weight: 700;
            color: #16a34a;
            line-height: 1;
        }

        .cell-empty {
            font-size: 16px;
            color: #d1d5db;
            font-weight: 300;
            line-height: 1;
        }

        .cell-star {
            color: #f59e0b;
            font-size: 8px;
            vertical-align: super;
            line-height: 0;
        }

        /* flash */
        .cell.flash {
            animation: flash 2s ease-out forwards;
        }
        @@keyframes flash {
            0% {
                background: #fef08a;
                border-color: #facc15;
            }

            40% {
                background: #fef9c3;
                border-color: #fde68a;
            }

            100% {
                background: var(--bg);
                border-color: var(--border);
            }
        }

        .cell.filled.flash {
            animation: flashg 2s ease-out forwards;
        }
        @@keyframes flashg {
            0% {
                background: #6ee7b7;
                border-color: #10b981;
            }

            40% {
                background: #a7f3d0;
                border-color: #34d399;
            }

            100% {
                background: #f0fdf4;
                border-color: #86efac;
            }
        }

        /* edit form inside cell */
        .ef {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }

        .ef-label {
            font-size: 8px;
            color: var(--accent);
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .04em;
        }

        .ef input {
            width: 100%;
            padding: 4px 5px;
            border-radius: 5px;
            border: 1.5px solid var(--accent);
            font-size: 11px;
            font-weight: 600;
            color: var(--text);
            background: #fff;
            outline: none;
            text-align: center;
            box-shadow: 0 0 0 3px rgba(79,110,247,.1);
        }

        .ef-btns {
            display: flex;
            gap: 3px;
            width: 100%;
        }

        .ef-ok {
            flex: 1;
            padding: 3px 0;
            border-radius: 5px;
            font-size: 10px;
            font-weight: 700;
            background: var(--accent);
            color: #fff;
            border: none;
            cursor: pointer;
        }

            .ef-ok:hover {
                background: #3d5ce6;
            }

        .ef-cx {
            padding: 3px 5px;
            border-radius: 5px;
            font-size: 10px;
            background: #fff;
            border: 1.5px solid var(--border);
            color: var(--muted);
            cursor: pointer;
        }
    
        .sidebar {
            width: 240px;
            background: var(--surface);
            border-right: 1px solid var(--border);
            height: 100vh;
            position: fixed;
            top: 0;
            left: 0;
            display: flex;
            flex-direction: column;
            padding: 28px 20px;
        }

        .logo {
            font-size: 1.2rem;
            font-weight: 700;
            color: #003A8F;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 36px;
        }

        .logo-icon {
            width: 36px;
            height: 36px;
            background: #003A8F;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 1rem;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 14px;
            border-radius: 10px;
            color: var(--muted);
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
            margin-bottom: 4px;
        }

            .nav-item:hover {
                background: #f0f3ff;
                color: var(--accent);
            }

            .nav-item.active {
                background: #eef1ff;
                color: var(--accent);
                font-weight: 600;
            }

        .nav-section {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 20px 0 8px 14px;
        }


        .main {
            margin-left: 240px;
            height: 100vh;
            display: flex;
            flex-direction: column;
            overflow: hidden; /* ← สำคัญ ห้าม scroll ทั้งหน้า */
        }

        .page-content {
            padding: 28px;
        }

        .tab-bar {
            display: flex;
            margin-left: 30px;
            align-items: flex-end;
            gap: 2px;
            padding: 8px 12px 0;
            background: #f4f6fb;
            
            min-height: 44px;
            overflow-x: auto;
            flex-shrink: 0;
            scrollbar-width: none;
        }

            .tab-bar::-webkit-scrollbar {
                display: none;
            }

        .tab-item {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 7px 14px;
            font-size: 0.82rem;
            font-weight: 500;
            border-radius: 8px 8px 0 0;
            cursor: pointer;
            white-space: nowrap;
            border: 1px solid var(--border);
            border-bottom: none;
            color: var(--muted);
            background: #ffffff;
            transition: all 0.15s;
            position: relative;
            bottom: -1px;
            user-select: none;
        }

            .tab-item:hover {
                color: #003A8F;
                border-color: #003A8F;
            }

            .tab-item.active {
                color: #ffffff;
                background: #003A8F;
                border-color: #003A8F;
                border-bottom-color: #003A8F;
            }

        /* ── Tab Content Area ── */
        .tab-content-area {
            margin: 0 60px 10px 30px;
            flex: 1;
            overflow: hidden;
            position: relative;
            background: var(--bg);
            border-block: none;
        }

        .tab-panel {
            display: none;
            height: 100%;
            overflow-y: auto;
            background: #ffffff;
            padding: 32px 40px;
           
            border: none !important; /* ← เพิ่ม */
            outline: none;
        }

            .tab-panel.active {
                display: block;
                border-top: none;
            }

            /* Scrollbar สวย */
            .tab-panel::-webkit-scrollbar {
                width: 5px;
            }

            .tab-panel::-webkit-scrollbar-track {
                background: transparent;
            }

            .tab-panel::-webkit-scrollbar-thumb {
                background: var(--border);
                border-radius: 10px;
            }

                .tab-panel::-webkit-scrollbar-thumb:hover {
                    background: var(--muted);
                }

        /* ── Welcome screen ── */
        .tab-welcome {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            gap: 12px;
            color: var(--muted);
            background: var(--bg);
        }

            .tab-welcome i {
                font-size: 2.5rem;
                opacity: 0.4;
            }

            .tab-welcome p {
                font-size: 0.85rem;
            }

        .sidebar-profile {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 14px;
            border-radius: 12px;
            border-top: 1px solid var(--border);
            cursor: pointer;
            transition: background 0.2s;
        }

            .sidebar-profile:hover {
                background: #f0f3ff;
            }


        .avatar-initials {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: var(--accent);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.8rem;
            font-weight: 700;
            flex-shrink: 0;
        }

        .profile-name {
            font-size: 0.85rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .profile-role {
            font-size: 0.75rem;
            color: var(--muted);
        }

        /* ── Task Items (Worker Rows) ── */
        .task-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 0;
            border-bottom: 1px solid var(--border);
            font-size: 0.88rem;
            transition: background 0.15s;
        }

            .task-item:last-child {
                border-bottom: none;
            }

        .task-check {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #eef1ff;
            color: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.6rem;
            font-weight: 700;
            flex-shrink: 0;
        }

        .task-name {
            flex: 1;
            font-weight: 500;
        }

        .task-date {
            color: var(--muted);
            font-size: 0.78rem;
            font-family: 'DM Mono', monospace;
        }

        .task-tag {
            font-size: 0.72rem;
            font-weight: 600;
            padding: 3px 9px;
            border-radius: 20px;
        }

        .tag-todo {
            background: #f1f5f9;
            color: var(--todo);
        }

        .tag-inprogress {
            background: #eef1ff;
            color: var(--inprogress);
        }

        .tag-done {
            background: #f0fdf4;
            color: var(--done);
        }

        .tag-overdue {
            background: #fef2f2;
            color: var(--overdue);
        }

        /* ── Breadcrumb ── */
        .bc {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 0.78rem;
            color: var(--muted);
            margin-bottom: 20px;
        }

        .bc-item {
            cursor: pointer;
            padding: 3px 8px;
            border-radius: 20px;
            transition: all .15s;
        }

            .bc-item:hover {
                background: var(--surface);
                color: var(--text);
            }

            .bc-item.active {
                color: var(--accent);
                font-weight: 600;
            }

        .bc-sep {
            color: var(--border);
        }

        /* ── Kanban header (WC header) ── */
        .kanban-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 14px;
        }

        .kanban-title {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--muted);
        }

        .kanban-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .kanban-count {
            font-size: 0.75rem;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 1px 8px;
            color: var(--muted);
            font-family: 'DM Mono', monospace;
        }

        /* ── Add inline ── */
        .btn-add-inline {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            width: 100%;
            padding: 9px;
            border: 1px dashed var(--border);
            border-radius: 10px;
            background: none;
            color: var(--muted);
            font-family: 'DM Sans', sans-serif;
            font-size: 0.78rem;
            cursor: pointer;
            margin-top: 8px;
            transition: all .15s;
        }

            .btn-add-inline:hover {
                border-color: var(--accent);
                color: var(--accent);
                background: #eef1ff;
            }

        /* ── Del btn ── */
        .del-btn {
            width: 26px;
            height: 26px;
            border-radius: 6px;
            border: 1px solid var(--border);
            background: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all .15s;
            flex-shrink: 0;
        }

            .del-btn:hover {
                background: #fef2f2;
                border-color: #fecaca;
                color: var(--overdue);
            }

        /* ── Section label ── */
        .nav-section {
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            text-transform: uppercase;
            color: var(--muted);
            margin: 0 0 12px 0;
        }

        /* ── WC Grid ── */
        .wc-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
        }

        /* ── Empty ── */
        .kanban-empty {
            text-align: center;
            color: var(--muted);
            font-size: 0.8rem;
            padding: 20px 0;
        }

            .kanban-empty i {
                font-size: 1.5rem;
                display: block;
                margin-bottom: 6px;
                opacity: .4;
            }

        /* ── Loading ── */
        .loading {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            color: var(--muted);
            font-size: 0.82rem;
            gap: 8px;
        }

        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(8px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade-in {
            animation: fadeUp .2s ease both;
        }

        /* pagination-circle ใช้กับ pagination WC */
        .pagination-circle {
            display: flex;
            justify-content: center;
            gap: 10px;
            padding-bottom: 5px;
        }

        .page-btn {
            width: 34px;
            height: 34px;
            border-radius: 50%;
            border: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.85rem;
            color: #6b7280;
            cursor: pointer;
        }

            .page-btn.active {
                background: var(--accent);
                color: white;
                border: none;
            }

        .chart-container {
            margin-top: 20px;
        }

        .vchart {
            display: flex;
            align-items: flex-end;
            justify-content: space-around;
            height: 200px;
        }

        .bar-item {
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .bar {
            width: 32px;
            background: #2563eb;
            border-radius: 6px 6px 0 0;
        }

        .bar-label {
            margin-top: 6px;
            font-size: 0.75rem;
            color: #6b7280;
        }

        .filter-bar {
            display: flex;
            gap: 10px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .search-wrap {
            position: relative;
            flex: 1;
            min-width: 200px;
        }

            .search-wrap i {
                position: absolute;
                left: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: var(--muted);
            }

        .filter-input {
            width: 100%;
            padding: 10px 14px 10px 36px;
            border: 1px solid var(--border);
            border-radius: 10px;
        }

        .filter-select {
            padding: 10px 14px;
            border: 1px solid var(--border);
            border-radius: 10px;
        }

        .bottom-grid {
            display: grid;
            gap: 20px;
        }

        .bottom-grid-approve {
            display: grid;
            grid-template-columns: 1fr 1.6fr;
            gap: 20px;
        }

        .card-box {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 24px;
            animation: fadeUp 0.5s ease both;
            animation-delay: 0.3s;
        }


        /* ── Page Header ── */
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .page-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text);
        }

        .page-sub {
            font-size: 0.78rem;
            color: var(--muted);
        }

        /* ── Tree ── */
        .tree-body {
            max-height: calc(100vh - 220px);
            overflow-y: auto;
            padding-right: 4px;
        }

        .t-div, .t-dept, .t-sec {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 10px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 0.8rem;
            transition: all .15s;
        }

            .t-div:hover,
            .t-dept:hover,
            .t-sec:hover {
                background: #f4f6fb;
            }

            .t-sec.active {
                background: #eef1ff;
                color: var(--accent);
                font-weight: 600;
            }

        .t-arrow {
            font-size: 0.65rem;
            transition: transform .2s;
        }

            .t-arrow.open {
                transform: rotate(90deg);
            }

        .t-cnt {
            font-size: 0.7rem;
            color: var(--muted);
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 0 6px;
        }

        .t-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        /* ── Detail Panel ── */
        .empty-detail {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            gap: 8px;
            color: var(--muted);
        }

            .empty-detail i {
                font-size: 1.8rem;
                opacity: .4;
            }

        /* ── Breadcrumb ── */
        .sec-breadcrumb {
            font-size: 0.75rem;
            display: flex;
            justify-content: space-between; 
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 18px;
            flex-direction: column;
        }

        /* LEFT */
        .bc-left {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            color: var(--muted);
        }

            .bc-left span {
                color: var(--muted);
            }

        .bc-current {
            color: var(--text);
            font-weight: 600;
        }

        /* RIGHT (buttons) */
        .bc-actions {
            display: flex;
            gap: 8px;
            justify-content: flex-end; 
        }

            /* ปรับปุ่มให้ดู modern */
            .bc-actions .btn {
                padding: 4px 12px;
                font-size: 0.72rem;
                border-radius: 8px;
            }

            /* hover */
            .bc-actions .btn-primary {
                background: var(--accent);
                border: none;
            }

            .bc-actions .btn-light {
                background: #f8fafc;
                border: 1px solid var(--border);
            }

        /* ── Status Badge ── */
        .stat-badge {
            font-size: 0.7rem;
            padding: 3px 8px;
            border-radius: 20px;
            font-weight: 600;
        }

        .badge-full {
            background: #f0fdf4;
            color: var(--done);
        }

        .badge-part {
            background: #fff7ed;
            color: var(--warn);
        }

        .badge-empty {
            background: #f1f5f9;
            color: var(--muted);
        }

        /* ── Level Row ── */
        .lvl-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }

            .lvl-row:last-child {
                border-bottom: none;
            }

        .lvl-cell-left {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .lvl-cell-right {
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }

        /* ── Approver Chip ── */
        .ap-chip {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 6px 10px;
            border-radius: 10px;
            font-size: 0.75rem;
        }

        .ap-av {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            background: rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.7rem;
            font-weight: 700;
        }

        .ap-name {
            font-weight: 600;
        }

        .ap-id {
            font-size: 0.68rem;
            opacity: .7;
        }

        /* ── Buttons ── */
        .btn-icon {
            width: 28px;
            height: 28px;
            border-radius: 8px;
            border: 1px solid var(--border);
            background: none;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-icon:hover {
                background: #eef1ff;
                color: var(--accent);
            }

            .btn-icon.del:hover {
                background: #fef2f2;
                color: var(--overdue);
            }

        .btn-assign {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 0.75rem;
            padding: 5px 10px;
            border-radius: 8px;
            border: 1px dashed var(--border);
            background: none;
            cursor: pointer;
            transition: all .15s;
        }

            .btn-assign:hover {
                border-color: var(--accent);
                color: var(--accent);
                background: #eef1ff;
            }

        .btn-new {
            font-size: 0.72rem;
            padding: 6px 10px;
            border-radius: 8px;
            border: none;
            background: var(--accent);
            color: white;
            cursor: pointer;
        }

        /* ── Input ── */
        .edit-input {
            padding: 6px 8px;
            border-radius: 8px;
            border: 1px solid var(--border);
            font-size: 0.75rem;
        }

        .w-id {
            width: 110px;
        }

        .w-name {
            width: 160px;
        }

        /* ── Tags Level Color ── */
        .tag-l1 {
            background: #ecfdf5;
            color: #065f46;
        }

        .tag-l2 {
            background: #eef1ff;
            color: #3730a3;
        }

        .tag-l3 {
            background: #fffbeb;
            color: #92400e;
        }

        .tag-l4 {
            background: #fff1f2;
            color: #9f1239;
        }

        .tag-gm {
            background: #faf5ff;
            color: #581c87;
        }
    </style>
</head>
<body>

    @{
        var userName = Context.Session.GetString("UserName") ?? "Unknown";

        // ดึง initials ด้วย C#
        var parts = userName.Trim().Split(' ');
        var initials = parts.Length == 1
        ? parts[0][0].ToString()
        : $"{parts[0][0]}{parts[^1][0]}";

        initials = initials.ToUpper();
    }

    <!-- Sidebar อยู่ที่นี่ครั้งเดียว -->
    <div class="sidebar">
        <div class="logo">
            <div class="logo-icon"><i class="bi bi-database-fill-gear"></i></div>
            Maintenance Data
        </div>
        <div class="nav-section">Master Data</div>
        <a class="nav-item" onclick="openTab('@Url.Action("Index", "MasterData")', 'Asset Hierarchy', 'bi-diagram-3', 'asset')">
            <i class="bi bi-diagram-3"></i> Asset Hierarchy
        </a>
        <a class="nav-item" onclick="openTab('@Url.Action("MaintenanceScheduleIndex", "MasterData")', 'Maintenance Schedule', 'bi-calendar2-check', 'schedule')">
            <i class="bi bi-calendar2-check"></i> Maintenance Schedule
        </a>
        <a class="nav-item" onclick="openTab('@Url.Action("EmployeeIndex", "MasterData")', 'Workforce Management', 'bi-people', 'workforce')">
            <i class="bi bi-people"></i> Workforce Management
        </a>
        <a class="nav-item" onclick="openTab('@Url.Action("ApprovalConfigIndex", "MasterData")', 'Approval Configuration', 'bi-people', 'approval')">
            <i class="bi bi-people"></i> Approval Configuration
        </a>
        
        <div class="nav-section">Transaction</div>
        <div class="nav-section">Report</div>

        

        <div style="flex:1"></div>

        <!-- Profile อยู่ล่างสุด -->
        <!-- Sidebar Profile with Dropdown -->
        <div class="dropup">
            <div class="sidebar-profile" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer">
                <div class="avatar-initials">@initials</div>
                <div style="flex:1; min-width:0">
                    <div class="profile-name">@userName</div>
                    <div class="profile-role">
                        @(Context.Session.GetString("UserRole") ?? "User")
                    </div>
                </div>
                <i class="bi bi-three-dots-vertical text-muted"></i>
            </div>

            <ul class="dropdown-menu mb-2" style="width:220px">
                <li>
                    <a class="dropdown-item" href="@Url.Action("Index", "Profile")">
                        <i class="bi bi-person me-2"></i> My Profile
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" href="@Url.Action("Settings", "MasterData")">
                        <i class="bi bi-layers me-2"></i> Master Data
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" href="@Url.Action("Settings", "Account")">
                        <i class="bi bi-gear me-2"></i> Settings
                    </a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item text-danger" href="@Url.Action("Logout", "Account")">
                        <i class="bi bi-box-arrow-left me-2"></i> Sign Out
                    </a>
                </li>
            </ul>
        </div>
    </div>

    @* ── Modal ── *@
    <div class="modal fade" id="insertModal" tabindex="-1" aria-labelledby="insertModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:16px; border:none; box-shadow:0 20px 60px rgba(0,0,0,0.15)">

                @* Header *@
                <div class="modal-header" style="border-bottom:1px solid var(--border); padding:20px 24px">
                    <h5 class="modal-title fw-bold" id="insertModalLabel">
                        <i class="bi bi-plus-circle me-2" style="color:var(--accent)"></i> Add New Asset
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body" style="padding:24px">

                    @* Name *@
                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:0.85rem">Name <span class="text-danger">*</span></label>
                        <input type="text" name="Name" id="inputName" class="form-control" placeholder="Enter name" required>
                        <div class="invalid-feedback">Please enter a name.</div>
                    </div>

                    @* Code *@
                    <div class="mb-3">
                        <label class="form-label fw-semibold" style="font-size:0.85rem">Code</label>
                        <input type="text" name="Code" class="form-control" placeholder="e.g. EQ-0001">
                    </div>

                    @* 2 คอลัมน์ — Rank + Status *@
                    <div class="row g-3 mb-3">

                        <div class="col-6">
                            <label class="form-label fw-semibold" style="font-size:0.85rem">Rank <span class="text-danger">*</span></label>
                            <select name="Rank" class="form-select" required>
                                <option value="">-- Select Rank --</option>
                                <option value="S">Rank S - Super Critical</option>
                                <option value="A">Rank A - Critical</option>
                                <option value="B">Rank B - Important</option>
                                <option value="C">Rank C - Normal</option>

                            </select>
                        </div>

                        <div class="col-6">
                            <label class="form-label fw-semibold" style="font-size:0.85rem">Status <span class="text-danger">*</span></label>
                            <select name="Status" class="form-select" required>
                                <option value="">-- Select Status --</option>
                                <option value="Active">Active</option>
                                <option value="Maintenance">Maintenance</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Retired">Retired</option>
                            </select>
                        </div>

                    </div>
                </div>

                @* Footer *@
                <div class="modal-footer" style="border-top:1px solid var(--border); padding:16px 24px; gap:8px">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn" style="background:var(--accent); color:white; font-weight:600">
                        <i class="bi bi-floppy me-1"></i> Save
                    </button>
                </div>

            </div>
        </div>
    </div>
    <div class="modal fade" id="addWorkerModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius:16px; border:none; box-shadow:0 20px 60px rgba(0,0,0,0.15)">

                <div class="modal-header" style="border-bottom:1px solid var(--border); padding:20px 24px">
                    <div>
                        <h5 class="modal-title fw-bold">Add Worker</h5>
                        <div id="modalSub" style="font-size:0.78rem; color:var(--muted); margin-top:2px"></div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body" style="padding:20px 24px">
                    <div style="display:flex; align-items:center; gap:8px; background:var(--bg); border:1px solid var(--border); border-radius:10px; padding:8px 12px; margin-bottom:12px">
                        <i class="bi bi-search" style="color:var(--muted); font-size:0.85rem"></i>
                        <input type="text" id="workerSearch" placeholder="Search workers..."
                               oninput="orgFilterWorkers()"
                               style="border:none; background:transparent; outline:none; font-family:'DM Sans',sans-serif; font-size:0.85rem; width:100%">
                    </div>
                    <div id="workerModalList" style="max-height:240px; overflow-y:auto"></div>
                    <div id="selCount" style="font-size:0.78rem; color:var(--muted); padding-top:10px; border-top:1px solid var(--border); margin-top:8px">0 selected</div>
                </div>

                <div class="modal-footer" style="border-top:1px solid var(--border); padding:16px 24px; gap:8px">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn-new" onclick="orgConfirmAdd()">
                        <i class="bi bi-person-plus"></i> Add Selected
                    </button>
                </div>

            </div>
        </div>
    </div>
    <div class="modal fade" id="apModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content"
                 style="border-radius:12px; border:1px solid #e2e8f0; overflow:hidden; box-shadow:0 8px 32px rgba(0,0,0,0.18);">

                <!-- Header -->
                <div style="padding:16px 20px 14px; border-bottom:1px solid #e2e8f0; display:flex; justify-content:space-between;">
                    <div>
                        <div style="font-size:15px; font-weight:600;" id="apModalTitle">เลือกผู้อนุมัติ</div>
                        <div style="font-size:12px; color:#6b7280; margin-top:3px" id="apModalSub"></div>
                    </div>
                    <button type="button" class="btn-close" onclick="closeApModal()"></button>
                </div>

                <!-- Search -->
                <div style="padding:12px 16px; border-bottom:1px solid #f1f5f9;">
                    <input id="apSearch" type="text"
                           placeholder="ค้นหาชื่อหรือรหัสพนักงาน..."
                           oninput="filterApList(this.value)"
                           style="width:100%; padding:8px 12px; border:1px solid #cbd5e0; border-radius:8px; font-size:13px; background:#f8fafc;">
                </div>

                <!-- Employee List -->
                <div id="apList"
                     style="overflow-y:auto; max-height:50vh; padding:6px 0;">
                </div>

                <!-- Footer -->
                <div style="padding:12px 20px; border-top:1px solid #e2e8f0; display:flex; justify-content:flex-end;">
                    <button class="btn btn-light" onclick="closeApModal()">ยกเลิก</button>
                </div>

            </div>
        </div>
    </div>



    <!-- ทุก View มาแสดงตรงนี้ -->
    <div class="main" id="mainContent">
        <div class="tab-bar" id="tabBar"></div>
        <div class="tab-content-area" id="tabContent">
            <div class="tab-panel active" id="welcomeTab">
                @RenderBody()
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="~/js/tabLoader.js"></script>
    <script src="~/js/maintenanceschedule.js"></script>


    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
